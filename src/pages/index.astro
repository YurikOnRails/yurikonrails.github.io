---
import Base from '../layouts/Base.astro'
import Icon from '../components/Icon.astro'
import { profile } from '../data/profile'
import { getPublishedEssays } from '../lib/content'
import { getCollection } from 'astro:content'
import { builds } from '../data/builds'

// Live content
const essays = await getPublishedEssays()
const latestEssay = essays[0]

const allField = await getCollection('field')
const fieldSorted = allField.sort((a, b) => b.data.takenOn.getTime() - a.data.takenOn.getTime())
const latestField = fieldSorted[0]

const allBooks = await getCollection('books')
const currentlyReading = allBooks.find((b) => b.data.status === 'reading')
const booksRead = allBooks.filter((b) => b.data.status === 'finished').length

const activeBuilds = builds.filter((b) => b.status === 'active').length

const nowEntries = await getCollection('now')
const nowEntry = nowEntries[0]
const nowDate = nowEntry?.data.updatedAt
const daysSinceNow = nowDate ? Math.floor((Date.now() - nowDate.getTime()) / 86400000) : null
const nowLabel = daysSinceNow === 0 ? 'today' : daysSinceNow === 1 ? 'yesterday' : daysSinceNow != null ? `${daysSinceNow}d ago` : ''
const nowFresh = daysSinceNow != null && daysSinceNow < 14
---

<Base
  title={profile.name}
  description={profile.bio}
>
  {/* ── Centered composition ── */}
  <section class="home-layout">
    <div class="home-center">

      {/* Avatar */}
      <div class="hero-avatar" id="hero-avatar">
        <img
          src={profile.avatar}
          alt={profile.name}
          class="h-full w-full object-cover"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="hidden h-full w-full items-center justify-center bg-surface text-[#3f3f46] text-3xl font-[family-name:var(--font-heading)]">
          {profile.name.split(' ').map((n) => n[0]).join('')}
        </div>
      </div>

      {/* Name + animated underline */}
      <div class="name-wrapper">
        <h1 class="home-name" id="hero-name">{profile.name}</h1>
        <span class="name-glint" id="name-glint" aria-hidden="true"></span>
        <svg class="name-underline" id="name-underline" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true">
          <path d="M 2 8 C 40 2, 90 11, 150 6 C 210 1, 260 10, 298 7" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      {/* Bio */}
      <p class="home-bio" id="hero-bio">
        {profile.bio}
      </p>

      {/* Divider */}
      <div class="home-divider" id="hero-divider" />

      {/* Nav grid — live data links */}
      <nav class="home-nav" id="hero-nav">
        <a href="/field" class="nav-item" data-nav>
          <span class="nav-label">Field</span>
          <span class="nav-sep">·</span>
          <span class="nav-value">
            <span class="nav-count" data-count={fieldSorted.length}>{fieldSorted.length}</span> series
          </span>
        </a>

        <a href="/essays" class="nav-item" data-nav>
          <span class="nav-label">Essays</span>
          <span class="nav-sep">·</span>
          <span class="nav-value">
            <span class="nav-count" data-count={essays.length}>{essays.length}</span> published
          </span>
        </a>

        <a href="/books" class="nav-item" data-nav>
          <span class="nav-label">Books</span>
          <span class="nav-sep">·</span>
          <span class="nav-value">
            {currentlyReading
              ? <span class="nav-reading">{currentlyReading.data.title}</span>
              : <><span class="nav-count" data-count={booksRead}>{booksRead}</span> read</>
            }
          </span>
        </a>

        <a href="/builds" class="nav-item" data-nav>
          <span class="nav-label">Builds</span>
          <span class="nav-sep">·</span>
          <span class="nav-value">
            <span class="nav-count" data-count={activeBuilds}>{activeBuilds}</span> active
          </span>
        </a>
      </nav>

      {/* Now — standalone centered */}
      <a href="/now" class="now-link" id="hero-now" data-nav>
        <span class="nav-label">Now</span>
        {nowFresh && (
          <span class="now-indicator">
            <span class="now-ping" />
            <span class="now-dot" />
          </span>
        )}
        <span class="nav-value now-meta">
          {nowFresh ? `Updated ${nowLabel}` : 'Status'}
        </span>
      </a>

      {/* Social */}
      <div class="home-social" id="hero-social">
        {profile.social.github && (
          <a href={profile.social.github} target="_blank" rel="noopener noreferrer" class="social-link">
            <Icon name="github" size={16} />
          </a>
        )}
        {profile.social.telegram && (
          <a href={profile.social.telegram} target="_blank" rel="noopener noreferrer" class="social-link">
            <Icon name="telegram" size={16} />
          </a>
        )}
      </div>

    </div>
  </section>
</Base>

{/* ── GSAP entrance choreography ── */}
<script>
  import { gsap } from 'gsap'
  import { SplitText } from 'gsap/SplitText'

  gsap.registerPlugin(SplitText)

  function initHomeAnimation() {
    const nameEl = document.getElementById('hero-name')
    const avatarEl = document.getElementById('hero-avatar')
    const bioEl = document.getElementById('hero-bio')
    const dividerEl = document.getElementById('hero-divider')
    const navEl = document.getElementById('hero-nav')
    const nowEl = document.getElementById('hero-now')
    const socialEl = document.getElementById('hero-social')

    if (!nameEl) return

    // Split name into characters
    const split = new SplitText(nameEl, {
      type: 'chars',
      charsClass: 'char',
    })

    const underlinePath = document.querySelector<SVGPathElement>('#name-underline path')
    const glintEl = document.getElementById('name-glint')

    const navItems = navEl ? navEl.querySelectorAll('[data-nav]') : []
    const allNavItems = [...navItems, nowEl].filter(Boolean)
    const counters = document.querySelectorAll('.nav-count')

    // Set initial states
    gsap.set(avatarEl, { opacity: 0, scale: 0.85 })
    gsap.set(split.chars, { yPercent: 110, opacity: 0, filter: 'blur(8px)' })
    gsap.set(bioEl, { opacity: 0, y: 12 })
    gsap.set(dividerEl, { scaleX: 0 })
    gsap.set(allNavItems, { opacity: 0, y: 8 })
    gsap.set(socialEl, { opacity: 0 })
    gsap.set(glintEl, { xPercent: -200, opacity: 0 })
    if (underlinePath) {
      const pl = underlinePath.getTotalLength()
      gsap.set(underlinePath, { strokeDasharray: pl, strokeDashoffset: pl })
    }

    // Set counters to 0 initially
    counters.forEach((c) => {
      const target = parseInt(c.dataset.count || '0', 10)
      c.textContent = '0'
      c._countTarget = target
    })

    // Build timeline
    const tl = gsap.timeline({
      defaults: { ease: 'power3.out' },
      delay: 0.15,
    })

    // 1. Avatar
    tl.to(avatarEl, {
      opacity: 1,
      scale: 1,
      duration: 0.5,
    })

    // 2. Name — character reveal with blur
    tl.to(split.chars, {
      yPercent: 0,
      opacity: 1,
      filter: 'blur(0px)',
      duration: 0.6,
      stagger: 0.03,
    }, '-=0.3')

    // 2.5. Glint sweep across name
    tl.to(glintEl, {
      xPercent: 320,
      opacity: 1,
      duration: 0.5,
      ease: 'power2.in',
    }, '-=0.05')
    tl.to(glintEl, { opacity: 0, duration: 0.08 }, '-=0.04')

    // 2.6. SVG underline draws in
    if (underlinePath) {
      tl.to(underlinePath, {
        strokeDashoffset: 0,
        duration: 0.85,
        ease: 'power2.inOut',
      }, '-=0.15')
    }

    // 3. Bio
    tl.to(bioEl, {
      opacity: 1,
      y: 0,
      duration: 0.4,
    }, '-=0.25')

    // 4. Divider — draws from center
    tl.to(dividerEl, {
      scaleX: 1,
      duration: 0.5,
      ease: 'power2.inOut',
    }, '-=0.15')

    // 5. Nav items — staggered
    tl.to(allNavItems, {
      opacity: 1,
      y: 0,
      duration: 0.4,
      stagger: 0.06,
    }, '-=0.2')

    // 6. Counter animation
    counters.forEach((c) => {
      const target = c._countTarget
      if (target > 0) {
        const obj = { val: 0 }
        tl.to(obj, {
          val: target,
          duration: 0.8,
          ease: 'power2.out',
          snap: { val: 1 },
          onUpdate: () => { c.textContent = String(Math.round(obj.val)) },
        }, '-=0.6')
      }
    })

    // 7. Social
    tl.to(socialEl, {
      opacity: 1,
      duration: 0.3,
    }, '-=0.4')

    // ── Avatar 3D tilt on hover ──
    if (avatarEl instanceof HTMLElement) {
      avatarEl.style.transformStyle = 'preserve-3d'
      avatarEl.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = avatarEl.getBoundingClientRect()
        const x = (e.clientX - rect.left - rect.width / 2) / (rect.width / 2)
        const y = (e.clientY - rect.top - rect.height / 2) / (rect.height / 2)
        gsap.to(avatarEl, {
          rotationX: -y * 15,
          rotationY: x * 15,
          scale: 1.06,
          duration: 0.3,
          ease: 'power2.out',
          transformPerspective: 600,
        })
      })
      avatarEl.addEventListener('mouseleave', () => {
        gsap.to(avatarEl, {
          rotationX: 0, rotationY: 0, scale: 1,
          duration: 0.55, ease: 'back.out(1.5)',
        })
      })
    }

    // ── Cursor aura ──
    const homeLayout = document.querySelector('.home-layout')
    if (homeLayout instanceof HTMLElement) {
      homeLayout.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = homeLayout.getBoundingClientRect()
        homeLayout.style.setProperty('--aura-x', `${((e.clientX - rect.left) / rect.width) * 100}%`)
        homeLayout.style.setProperty('--aura-y', `${((e.clientY - rect.top) / rect.height) * 100}%`)
      })
    }

    // ── Magnetic hover on nav items ──
    allNavItems.forEach((item) => {
      if (!(item instanceof HTMLElement)) return

      item.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = item.getBoundingClientRect()
        const x = e.clientX - rect.left - rect.width / 2
        const y = e.clientY - rect.top - rect.height / 2
        gsap.to(item, {
          x: x * 0.08,
          y: y * 0.08,
          duration: 0.3,
          ease: 'power2.out',
        })
      })

      item.addEventListener('mouseleave', () => {
        gsap.to(item, {
          x: 0,
          y: 0,
          duration: 0.4,
          ease: 'power2.out',
        })
      })
    })
  }

  // Run on load and on Astro page transitions
  initHomeAnimation()
  document.addEventListener('astro:after-swap', initHomeAnimation)
</script>

<style>
  /* ═══ Layout ═══ */
  .home-layout {
    height: calc(100dvh - 4rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    position: relative;
    --aura-x: 50%;
    --aura-y: 50%;
  }

  .home-layout::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      700px circle at var(--aura-x) var(--aura-y),
      rgba(196, 92, 40, 0.06),
      transparent 65%
    );
    z-index: 0;
  }

  .home-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 540px;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  /* ═══ Avatar ═══ */
  .hero-avatar {
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 9999px;
    overflow: hidden;
    margin-bottom: 1.75rem;
    position: relative;
    box-shadow:
      0 0 0 1px rgba(26, 26, 18, 0.10),
      0 0 24px rgba(196, 92, 40, 0.08);
  }

  @media (min-width: 768px) {
    .hero-avatar {
      width: 7rem;
      height: 7rem;
      margin-bottom: 2rem;
    }
  }

  /* ═══ Name ═══ */
  .name-wrapper {
    position: relative;
    width: 100%;
    margin-bottom: 1rem;
    padding-bottom: 16px;
  }

  .name-glint {
    position: absolute;
    top: 5%;
    left: 0;
    width: 25%;
    height: 75%;
    background: linear-gradient(
      105deg,
      transparent 0%,
      rgba(255, 252, 235, 0.55) 50%,
      transparent 100%
    );
    transform: skewX(-18deg);
    pointer-events: none;
    will-change: transform, opacity;
  }

  .name-underline {
    position: absolute;
    bottom: 0;
    left: 4%;
    width: 92%;
    height: 12px;
    overflow: visible;
  }

  .name-underline path {
    stroke: var(--color-accent);
    stroke-width: 2.5px;
    opacity: 0.6;
  }

  .home-name {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(3rem, 7vw, 6.5rem);
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--color-primary);
    margin-bottom: 0;
    overflow: hidden;
  }

  .home-name :global(.char) {
    display: inline-block;
    will-change: transform, opacity;
  }

  /* ═══ Bio ═══ */
  .home-bio {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #6b5f50;
    max-width: 28rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .home-bio {
      font-size: 1rem;
    }
  }

  /* ═══ Divider ═══ */
  .home-divider {
    width: 100%;
    max-width: 320px;
    height: 1px;
    background: rgba(26, 26, 18, 0.10);
    margin-bottom: 2rem;
    transform-origin: center;
  }

  /* ═══ Nav grid ═══ */
  .home-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 2.5rem;
    margin-bottom: 1rem;
  }

  .nav-item {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    border-radius: 2px;
    transition: background 0.2s;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-item:hover {
    background: rgba(26, 26, 18, 0.05);
  }

  .nav-item:hover .nav-label {
    color: var(--color-accent);
  }

  .nav-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8a7e6e;
    transition: color 0.2s;
  }

  .nav-sep {
    color: #c0b09a;
    font-size: 11px;
  }

  .nav-value {
    font-family: var(--font-ui);
    font-size: 13px;
    color: #6b5f50;
  }

  .nav-count {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-primary);
  }

  .nav-reading {
    font-family: var(--font-heading);
    font-size: 13px;
    color: var(--color-primary);
    font-style: italic;
  }

  /* ═══ Now link ═══ */
  .now-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    border-radius: 2px;
    text-decoration: none;
    margin-bottom: 1.75rem;
    transition: background 0.2s;
  }

  .now-link:hover {
    background: rgba(26, 26, 18, 0.05);
  }

  .now-link:hover .nav-label {
    color: var(--color-accent);
  }

  .now-indicator {
    position: relative;
    display: flex;
    width: 0.375rem;
    height: 0.375rem;
  }

  .now-ping {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background-color: #34d399;
    opacity: 0.5;
    animation: now-ping 2.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  .now-dot {
    position: relative;
    display: inline-flex;
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 9999px;
    background-color: #34d399;
  }

  @keyframes now-ping {
    75%, 100% {
      transform: scale(2.5);
      opacity: 0;
    }
  }

  .now-meta {
    font-size: 11px;
    color: #8a7e6e;
  }

  /* ═══ Social ═══ */
  .home-social {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .social-link {
    color: #8a7e6e;
    transition: color 0.2s;
  }

  .social-link:hover {
    color: var(--color-primary);
  }

  /* ═══ Mobile ═══ */
  @media (max-width: 767px) {
    .home-layout {
      height: auto;
      min-height: calc(100dvh - 4rem);
      padding: 3rem 1.5rem;
    }

    .home-nav {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .nav-item {
      justify-content: center;
    }

    .now-link {
      justify-content: center;
    }
  }
</style>
