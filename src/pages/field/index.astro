---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import GlobeMap from '../../components/GlobeMap.astro'
import { formatDate } from '../../lib/utils'

const allSeries = await getCollection('field')
const series = allSeries.sort((a, b) => b.data.takenOn.getTime() - a.data.takenOn.getTime())

const locations = series.map((s) => ({
  slug: s.id,
  title: s.data.title,
  location: s.data.location,
  lat: s.data.lat,
  lng: s.data.lng,
  year: s.data.takenOn.getFullYear(),
}))

const years = [...new Set(series.map((s) => s.data.takenOn.getFullYear()))].sort((a, b) => a - b)
const tripsByYear = Object.fromEntries(
  years.map((y) => [y, series.filter((s) => s.data.takenOn.getFullYear() === y).length])
)
---

<Base
  title="Field"
  description="Travel photography with maps and stories."
>
  <section class="mx-auto max-w-[var(--container-grid)] px-5 pt-12 pb-24">
    <h1 class="text-4xl md:text-6xl mb-4">Field</h1>
    <p class="text-secondary mb-10 max-w-xl">
      Travel photography with maps and stories.
    </p>

    {/* Map */}
    <div class="mb-12">
      <GlobeMap locations={locations} />
    </div>

    {/* Year filter */}
    {years.length > 0 && (
      <div class="year-filter mb-10" id="year-filter">
        {years.map((year) => (
          <button class="year-btn" data-year={year}>
            {year}<sup>{tripsByYear[year]}</sup>
          </button>
        ))}
        <span class="year-sep">·</span>
        <button class="year-btn active" data-year="all">All</button>
      </div>
    )}

    {/* Series grid */}
    <div id="field-grid" class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {series.map((s) => (
        <a
          href={`/field/${s.id}`}
          class="field-card group block rounded-sm border border-subtle overflow-hidden bg-card transition-all hover:bg-surface"
          data-year={s.data.takenOn.getFullYear()}
        >
          <div class="relative aspect-[16/10] overflow-hidden">
            <img
              src={s.data.cover}
              alt={s.data.title}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-card to-transparent" />
          </div>
          <div class="p-5">
            <div class="flex items-center gap-2 text-xs text-secondary mb-2">
              <span>{s.data.location}</span>
              <span class="text-subtle">·</span>
              <time datetime={s.data.takenOn.toISOString()}>
                {formatDate(s.data.takenOn, 'month-year')}
              </time>
            </div>
            <h2 class="text-lg font-[family-name:var(--font-heading)] group-hover:text-accent transition-colors">
              {s.data.title}
            </h2>
            <p class="mt-2 text-sm text-secondary line-clamp-2">
              {s.data.description}
            </p>
          </div>
        </a>
      ))}
    </div>

    {series.length === 0 && (
      <p class="text-secondary text-center py-20">No field series yet.</p>
    )}
  </section>

  <script>
    function initYearFilter() {
      const buttons = document.querySelectorAll('.year-btn')
      const cards = document.querySelectorAll('.field-card')
      const globeContainer = document.getElementById('globe-container')

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const year = (btn as HTMLElement).dataset.year

          buttons.forEach((b) => b.classList.remove('active'))
          btn.classList.add('active')

          cards.forEach((card) => {
            const el = card as HTMLElement
            const cardYear = el.dataset.year
            const show = year === 'all' || cardYear === year

            if (show) {
              el.style.display = ''
              requestAnimationFrame(() => {
                el.classList.remove('field-card--hidden')
              })
            } else {
              el.classList.add('field-card--hidden')
              setTimeout(() => {
                if (el.classList.contains('field-card--hidden')) {
                  el.style.display = 'none'
                }
              }, 300)
            }
          })

          if (globeContainer) {
            globeContainer.dispatchEvent(
              new CustomEvent('filter-year', { detail: { year } })
            )
          }
        })
      })
    }

    initYearFilter()
    document.addEventListener('astro:after-swap', initYearFilter)
  </script>

  <style is:global>
    .year-filter {
      display: flex;
      align-items: baseline;
      justify-content: center;
      flex-wrap: wrap;
      gap: 12px 20px;
      font-family: var(--font-mono);
    }

    .year-btn {
      background: none;
      border: none;
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 14px;
      letter-spacing: 0.04em;
      color: #52525b;
      padding: 8px 4px;
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      transition: color 0.2s;
    }

    .year-btn:hover {
      color: #a1a1aa;
    }

    .year-btn.active {
      color: #e8622c;
    }

    .year-btn sup {
      font-size: 10px;
      color: #3f3f46;
      margin-left: 1px;
      vertical-align: super;
      transition: color 0.2s;
    }

    .year-btn.active sup {
      color: rgba(232, 98, 44, 0.5);
    }

    .year-sep {
      color: #27272a;
      font-size: 14px;
      user-select: none;
    }

    /* Card transitions */
    .field-card {
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .field-card--hidden {
      opacity: 0;
      transform: translateY(8px);
    }
  </style>
</Base>
