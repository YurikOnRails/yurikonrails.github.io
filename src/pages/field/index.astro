---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import GlobeMap from '../../components/GlobeMap.astro'
import { formatDate } from '../../lib/utils'

const allSeries = await getCollection('field')
const series = allSeries.sort((a, b) => b.data.takenOn.getTime() - a.data.takenOn.getTime())

const locations = series.map((s) => ({
  slug: s.id,
  title: s.data.title,
  location: s.data.location,
  lat: s.data.lat,
  lng: s.data.lng,
  year: s.data.takenOn.getFullYear(),
}))

const years = [...new Set(series.map((s) => s.data.takenOn.getFullYear()))].sort((a, b) => b - a)
const tripsByYear = Object.fromEntries(
  years.map((y) => [y, series.filter((s) => s.data.takenOn.getFullYear() === y).length])
)
---

<Base title="Field" description="Travel photography — moments from the road, frame by frame.">
  <section class="mx-auto max-w-[var(--container-grid)] px-5 pt-12 pb-24">

    {/* ── Page header ── */}
    <div class="mb-12">
      <p class="kicker">Photography</p>
      <h1 class="text-4xl md:text-6xl mb-3">Field</h1>
      <p class="text-secondary max-w-xl">
        Moments from the road — shot on Panasonic GH5, frame by frame.
      </p>
    </div>

    {/* ── Globe map ── */}
    <div class="mb-14">
      <GlobeMap locations={locations} />
    </div>

    {/* ── Controls: year filter + view toggle ── */}
    <div class="field-controls">

      {years.length > 1 ? (
        <div class="year-filter" id="year-filter">
          <button class="year-btn active" data-year="all">All</button>
          <span class="year-sep">·</span>
          {years.map((year) => (
            <button class="year-btn" data-year={year}>
              {year}<sup>{tripsByYear[year]}</sup>
            </button>
          ))}
        </div>
      ) : (
        <div />
      )}

      {/* View toggle */}
      <div class="view-toggle" id="view-toggle" role="group" aria-label="View mode">
        <button class="toggle-btn active" id="btn-photo" data-view="photo" aria-label="Photo grid">
          {/* 2×2 grid icon */}
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
            <rect x="0.5" y="0.5" width="6" height="6" rx="0.5" fill="currentColor"/>
            <rect x="8.5" y="0.5" width="6" height="6" rx="0.5" fill="currentColor"/>
            <rect x="0.5" y="8.5" width="6" height="6" rx="0.5" fill="currentColor"/>
            <rect x="8.5" y="8.5" width="6" height="6" rx="0.5" fill="currentColor"/>
          </svg>
        </button>
        <button class="toggle-btn" id="btn-editorial" data-view="editorial" aria-label="Editorial view">
          {/* Varied layout icon: full-width top + two halves below */}
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
            <rect x="0.5" y="0.5" width="14" height="5.5" rx="0.5" fill="currentColor"/>
            <rect x="0.5" y="8.5" width="6" height="6" rx="0.5" fill="currentColor"/>
            <rect x="8.5" y="8.5" width="6" height="6" rx="0.5" fill="currentColor"/>
          </svg>
        </button>
      </div>

    </div>

    {/* ── Photo grid ── */}
    {series.length > 0 ? (
      <div id="field-grid" class="field-grid view-photo">
        {series.map((s, i) => {
          const photoCount = s.data.photos?.length ?? 0
          const videoCount = s.data.videos?.length ?? 0
          const badgeLabel =
            photoCount > 0 && videoCount > 0
              ? `${photoCount} · ${videoCount}`
              : photoCount > 0
                ? `${photoCount} photos`
                : videoCount > 0
                  ? `${videoCount} videos`
                  : null
          const isFeatured = i % 3 === 0

          return (
            <a
              href={`/field/${s.id}`}
              class="field-card group"
              data-year={s.data.takenOn.getFullYear()}
              data-featured={isFeatured ? '' : undefined}
            >
              <div class="card-inner">

                {/* Photo */}
                <img
                  src={s.data.cover}
                  alt={s.data.title}
                  loading="lazy"
                  decoding="async"
                  class="card-img"
                />

                {/* Overlay */}
                <div class="card-overlay" />

                {/* Badge */}
                {badgeLabel && (
                  <div class="card-badge">{badgeLabel}</div>
                )}

                {/* Text */}
                <div class="card-text">
                  <p class="card-kicker">
                    {s.data.location}
                    <span class="card-sep">·</span>
                    {s.data.takenOn.getFullYear()}
                  </p>
                  <h2 class="card-title">{s.data.title}</h2>
                </div>

              </div>
            </a>
          )
        })}
      </div>
    ) : (
      <p class="text-secondary text-center py-20">No field series yet.</p>
    )}

  </section>

  <script>
    function initFieldPage() {
      const grid = document.getElementById('field-grid') as HTMLElement | null
      const btnPhoto = document.getElementById('btn-photo')
      const btnEditorial = document.getElementById('btn-editorial')
      const yearBtns = document.querySelectorAll('.year-btn')
      const cards = document.querySelectorAll('.field-card')
      const globeContainer = document.getElementById('globe-container')

      if (!grid) return

      // ── View toggle ──
      const saved = (localStorage.getItem('field-view') as 'photo' | 'editorial') || 'photo'
      applyView(saved, false)

      btnPhoto?.addEventListener('click', () => applyView('photo'))
      btnEditorial?.addEventListener('click', () => applyView('editorial'))

      function applyView(mode: 'photo' | 'editorial', animate = true) {
        if (animate) {
          grid.style.opacity = '0'
          grid.style.transform = 'translateY(6px)'
        }

        const apply = () => {
          grid.className = `field-grid view-${mode}`
          btnPhoto?.classList.toggle('active', mode === 'photo')
          btnEditorial?.classList.toggle('active', mode === 'editorial')
          localStorage.setItem('field-view', mode)

          if (animate) {
            requestAnimationFrame(() => {
              grid.style.opacity = '1'
              grid.style.transform = 'translateY(0)'
            })
          }
        }

        animate ? setTimeout(apply, 180) : apply()
      }

      // ── Year filter ──
      yearBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          const year = (btn as HTMLElement).dataset.year

          yearBtns.forEach((b) => b.classList.remove('active'))
          btn.classList.add('active')

          cards.forEach((card) => {
            const el = card as HTMLElement
            const show = year === 'all' || el.dataset.year === year

            if (show) {
              el.style.display = ''
              requestAnimationFrame(() => el.classList.remove('card--hidden'))
            } else {
              el.classList.add('card--hidden')
              setTimeout(() => {
                if (el.classList.contains('card--hidden')) el.style.display = 'none'
              }, 350)
            }
          })

          globeContainer?.dispatchEvent(new CustomEvent('filter-year', { detail: { year } }))
        })
      })
    }

    initFieldPage()
    document.addEventListener('astro:after-swap', initFieldPage)
  </script>

  <style is:global>

    /* ── Controls bar ── */
    .field-controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      min-height: 44px;
    }

    /* ── Year filter ── */
    .year-filter {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 4px 12px;
    }

    .year-btn {
      background: none;
      border: none;
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-secondary);
      padding: 6px 2px;
      min-height: 36px;
      display: inline-flex;
      align-items: center;
      opacity: 0.4;
      transition: opacity 0.2s;
    }

    .year-btn:hover  { opacity: 0.7; }
    .year-btn.active { opacity: 1; color: var(--color-accent); }
    .year-btn sup    { font-size: 0.52rem; margin-left: 2px; vertical-align: super; }

    .year-sep {
      color: var(--color-secondary);
      opacity: 0.2;
      font-size: 0.75rem;
      font-family: var(--font-mono);
      user-select: none;
    }

    /* ── View toggle ── */
    .view-toggle {
      display: flex;
      align-items: center;
      gap: 2px;
      background: rgba(17, 17, 17, 0.07);
      border-radius: 5px;
      padding: 3px;
    }

    .toggle-btn {
      width: 34px;
      height: 34px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      background: none;
      cursor: pointer;
      border-radius: 3px;
      color: var(--color-secondary);
      opacity: 0.35;
      transition: opacity 0.15s, background 0.15s, color 0.15s, box-shadow 0.15s;
    }

    .toggle-btn:hover { opacity: 0.65; }

    .toggle-btn.active {
      background: #ffffff;
      color: var(--color-primary);
      opacity: 1;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
    }

    /* ── Grid base ── */
    .field-grid {
      display: grid;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .card--hidden {
      opacity: 0;
      transform: translateY(8px);
    }

    /* ──────────────────────────────────────
       MODE: PHOTO
       2-col grid, text hidden, hover reveal
    ────────────────────────────────────── */
    .view-photo {
      grid-template-columns: repeat(2, 1fr);
      gap: 2px;
    }

    .view-photo .card-inner {
      aspect-ratio: 4 / 3;
    }

    /* Overlay — invisible by default */
    .view-photo .card-overlay {
      opacity: 0;
      background: linear-gradient(
        to top,
        rgba(0, 0, 0, 0.82) 0%,
        rgba(0, 0, 0, 0.35) 45%,
        transparent 75%
      );
      transition: opacity 0.38s ease;
    }

    .view-photo .field-card:hover .card-overlay {
      opacity: 1;
    }

    /* Text — slides up on hover */
    .view-photo .card-text {
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.32s ease, transform 0.32s ease;
    }

    .view-photo .field-card:hover .card-text {
      opacity: 1;
      transform: translateY(0);
    }

    /* ──────────────────────────────────────
       MODE: EDITORIAL
       Varied grid, text always on
    ────────────────────────────────────── */
    .view-editorial {
      grid-template-columns: repeat(2, 1fr);
      gap: 3px;
    }

    .view-editorial .card-inner {
      aspect-ratio: 4 / 3;
    }

    /* Featured card — spans full width, cinematic ratio */
    @media (min-width: 768px) {
      .view-editorial .field-card[data-featured] {
        grid-column: span 2;
      }

      .view-editorial .field-card[data-featured] .card-inner {
        aspect-ratio: 21 / 9;
      }

      .view-editorial .field-card[data-featured] .card-title {
        font-size: clamp(1.5rem, 3vw, 2.375rem);
      }
    }

    /* Overlay — always on */
    .view-editorial .card-overlay {
      opacity: 1;
      background: linear-gradient(
        to top,
        rgba(0, 0, 0, 0.82) 0%,
        rgba(0, 0, 0, 0.3) 45%,
        rgba(0, 0, 0, 0.0) 72%,
        transparent 100%
      );
      transition: opacity 0.3s ease;
    }

    .view-editorial .field-card:hover .card-overlay {
      background: linear-gradient(
        to top,
        rgba(0, 0, 0, 0.9) 0%,
        rgba(0, 0, 0, 0.4) 45%,
        rgba(0, 0, 0, 0.05) 72%,
        transparent 100%
      );
    }

    /* Text — always visible */
    .view-editorial .card-text {
      opacity: 1;
      transform: none;
      transition: none;
    }

    /* ── Card shared styles ── */
    .field-card {
      display: block;
      text-decoration: none;
      transition: opacity 0.35s ease, transform 0.35s ease;
    }

    .card-inner {
      position: relative;
      overflow: hidden;
      background: #0d0d0d;
    }

    .card-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.75s ease-out;
    }

    .field-card:hover .card-img {
      transform: scale(1.04);
    }

    .card-overlay {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .card-badge {
      position: absolute;
      top: 0.875rem;
      right: 0.875rem;
      font-family: var(--font-mono);
      font-size: 0.58rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255, 255, 255, 0.82);
      background: rgba(0, 0, 0, 0.42);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      padding: 0.28rem 0.6rem;
      border-radius: 2px;
    }

    .card-text {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1.25rem;
      pointer-events: none;
    }

    .card-kicker {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.13em;
      color: rgba(255, 255, 255, 0.55);
      margin-bottom: 0.4rem;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .card-sep {
      color: var(--color-terra);
      opacity: 0.7;
    }

    .card-title {
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.95);
      line-height: 1.2;
      letter-spacing: -0.02em;
      transition: color 0.2s;
    }

    .field-card:hover .card-title {
      color: #ffffff;
    }

  </style>
</Base>
