---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import GlobeMap from '../../components/GlobeMap.astro'
import { formatDate } from '../../lib/utils'

const allSeries = await getCollection('field')
const series = allSeries.sort((a, b) => b.data.takenOn.getTime() - a.data.takenOn.getTime())

const locations = series.map((s) => ({
  slug: s.id,
  title: s.data.title,
  location: s.data.location,
  lat: s.data.lat,
  lng: s.data.lng,
  year: s.data.takenOn.getFullYear(),
}))

const years = [...new Set(series.map((s) => s.data.takenOn.getFullYear()))].sort((a, b) => b - a)
---

<Base
  title="Field"
  description="Travel photography with maps and stories."
>
  <section class="mx-auto max-w-[var(--container-grid)] px-5 pt-12 pb-24">
    <h1 class="text-3xl md:text-5xl mb-4">Field</h1>
    <p class="text-secondary mb-10 max-w-xl">
      Travel photography with maps and stories.
    </p>

    {/* Map */}
    <div class="mb-12">
      <GlobeMap locations={locations} />
    </div>

    {/* Year filter */}
    {years.length > 0 && (
      <div class="flex items-center gap-1 mb-8 overflow-x-auto scrollbar-none" id="year-filter">
        <button
          class="field-year-btn active"
          data-year="all"
        >
          All
        </button>
        {years.map((year) => (
          <button
            class="field-year-btn"
            data-year={year}
          >
            {year}
          </button>
        ))}
      </div>
    )}

    {/* Series grid */}
    <div id="field-grid" class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {series.map((s) => (
        <a
          href={`/field/${s.id}`}
          class="field-card group block rounded-2xl border border-subtle overflow-hidden bg-card transition-all hover:bg-surface"
          data-year={s.data.takenOn.getFullYear()}
        >
          <div class="relative aspect-[16/10] overflow-hidden">
            <img
              src={s.data.cover}
              alt={s.data.title}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-card to-transparent" />
          </div>
          <div class="p-5">
            <div class="flex items-center gap-2 text-xs text-secondary mb-2">
              <span>{s.data.location}</span>
              <span class="text-subtle">·</span>
              <time datetime={s.data.takenOn.toISOString()}>
                {formatDate(s.data.takenOn, 'month-year')}
              </time>
            </div>
            <h2 class="text-lg font-[family-name:var(--font-heading)] group-hover:text-accent transition-colors">
              {s.data.title}
            </h2>
            <p class="mt-2 text-sm text-secondary line-clamp-2">
              {s.data.description}
            </p>
          </div>
        </a>
      ))}
    </div>

    {series.length === 0 && (
      <p class="text-secondary text-center py-20">No field series yet.</p>
    )}
  </section>

  <script>
    function initYearFilter() {
      const buttons = document.querySelectorAll('.field-year-btn')
      const cards = document.querySelectorAll('.field-card')
      const globeContainer = document.getElementById('globe-container')

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const year = (btn as HTMLElement).dataset.year

          // Update active button
          buttons.forEach((b) => b.classList.remove('active'))
          btn.classList.add('active')

          // Filter cards
          cards.forEach((card) => {
            const cardYear = (card as HTMLElement).dataset.year
            const show = year === 'all' || cardYear === year
            ;(card as HTMLElement).style.display = show ? '' : 'none'
          })

          // Filter map markers
          if (globeContainer) {
            globeContainer.dispatchEvent(
              new CustomEvent('filter-year', { detail: { year } })
            )
          }
        })
      })
    }

    initYearFilter()
    document.addEventListener('astro:after-swap', initYearFilter)
  </script>

  <style is:global>
    .field-year-btn {
      padding: 6px 16px;
      font-size: 13px;
      font-family: var(--font-mono);
      letter-spacing: 0.02em;
      color: #52525b;
      border-radius: 100px;
      border: 1px solid transparent;
      background: transparent;
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s;
      white-space: nowrap;
      line-height: 1;
    }

    .field-year-btn:hover {
      color: #a1a1aa;
    }

    .field-year-btn.active {
      color: #e8622c;
      border-color: rgba(232, 98, 44, 0.25);
    }

    .scrollbar-none {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .scrollbar-none::-webkit-scrollbar {
      display: none;
    }
  </style>
</Base>
