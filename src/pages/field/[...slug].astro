---
import { getCollection, render } from 'astro:content'
import Base from '../../layouts/Base.astro'
import Icon from '../../components/Icon.astro'
import Map from '../../components/Map.astro'
import { formatDate } from '../../lib/utils'

export async function getStaticPaths() {
  const field = await getCollection('field')
  return field.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
const { title, description, location, takenOn, lat, lng, cover, photos, videos } = entry.data

const dateStr = formatDate(takenOn, 'month-year')

const photoMarkers = (photos || []).map((p, i) => ({
  src: p.src,
  caption: p.caption,
  lat: p.lat,
  lng: p.lng,
  index: i,
}))
---

<Base
  title={title}
  description={description}
  image={cover}
>
  <article class="mx-auto max-w-[var(--container-grid)] px-5 pt-8 pb-24">
    {/* Back link */}
    <a href="/field" class="inline-flex items-center gap-1 text-sm text-secondary hover:text-accent transition-colors mb-8">
      <Icon name="arrow-left" size={16} />
      <span>All series</span>
    </a>

    {/* Hero */}
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-3 text-sm text-secondary mb-4">
        <span>{location}</span>
        <span class="text-subtle">·</span>
        <time datetime={takenOn.toISOString()}>{dateStr}</time>
      </div>
      <h1 class="text-4xl md:text-6xl leading-tight mb-4">{title}</h1>
      <p class="text-secondary max-w-2xl">{description}</p>
    </header>

    {/* MapLibre map */}
    <div class="mb-12">
      <Map lat={lat} lng={lng} title={title} photos={photoMarkers} />
    </div>

    {/* Photo grid */}
    {photos && photos.length > 0 && (
      <div class="space-y-6 mb-12">
        {photos.map((photo, i) => (
          <figure id={`photo-${i}`}>
            <div class="overflow-hidden rounded-2xl">
              <img
                src={photo.src}
                alt={photo.caption || title}
                loading="lazy"
                decoding="async"
                class="w-full"
              />
            </div>
            <div class="mt-2 flex items-center justify-center gap-3">
              {photo.caption && (
                <figcaption class="text-sm text-secondary">
                  {photo.caption}
                </figcaption>
              )}
              {photo.lat != null && photo.lng != null && (
                <>
                  {photo.caption && <span class="text-subtle">·</span>}
                  <button
                    class="photo-coords text-xs text-secondary/50 hover:text-accent transition-colors font-[family-name:var(--font-mono)]"
                    data-lat={photo.lat}
                    data-lng={photo.lng}
                  >
                    {photo.lat.toFixed(4)}°, {photo.lng.toFixed(4)}°
                  </button>
                </>
              )}
            </div>
          </figure>
        ))}
      </div>
    )}

    {/* YouTube videos */}
    {videos && videos.length > 0 && (
      <div class="space-y-6 mb-12">
        {videos.map((video) => (
          <figure>
            <div class="relative aspect-video overflow-hidden rounded-xl bg-surface">
              <iframe
                srcdoc={`<style>*{padding:0;margin:0;overflow:hidden}html,body{height:100%}img,span{position:absolute;width:100%;top:0;bottom:0;margin:auto}span{height:48px;width:68px;text-align:center;font:48px/1.5 sans-serif;color:white;text-shadow:0 0 16px rgba(0,0,0,.5)}</style><a href='https://www.youtube.com/embed/${video.youtube}?autoplay=1'><img src='https://img.youtube.com/vi/${video.youtube}/maxresdefault.jpg'><span>▶</span></a>`}
                loading="lazy"
                allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                title={video.title}
                class="absolute inset-0 h-full w-full"
              />
            </div>
            {video.caption && (
              <figcaption class="mt-2 text-sm text-secondary text-center">
                {video.caption}
              </figcaption>
            )}
          </figure>
        ))}
      </div>
    )}

    {/* Body text */}
    <div class="prose mx-auto max-w-[var(--container-prose)]">
      <Content />
    </div>
  </article>

  <script>
    function initCoordLinks() {
      document.querySelectorAll('.photo-coords').forEach((btn) => {
        btn.addEventListener('click', () => {
          const mapContainer = document.getElementById('map-container')
          if (!mapContainer) return

          // Scroll to map
          mapContainer.scrollIntoView({ behavior: 'smooth', block: 'center' })

          // Dispatch event so Map.astro can fly to coordinates
          const lat = parseFloat((btn as HTMLElement).dataset.lat || '0')
          const lng = parseFloat((btn as HTMLElement).dataset.lng || '0')
          mapContainer.dispatchEvent(new CustomEvent('flyto', { detail: { lat, lng } }))
        })
      })
    }

    initCoordLinks()
    document.addEventListener('astro:after-swap', initCoordLinks)
  </script>
</Base>
