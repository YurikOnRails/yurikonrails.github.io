---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'

const allBooks = await getCollection('books')
const books = allBooks.sort((a, b) => b.data.yearRead - a.data.yearRead)

const reading = books.filter((b) => b.data.status === 'reading')
const finished = books.filter((b) => b.data.status === 'finished')
const dropped = books.filter((b) => b.data.status === 'dropped')
const listed = [...finished, ...dropped]

const ratingColor: Record<string, string> = {
  essential: 'text-accent',
  good: 'text-secondary',
  skip: 'text-[#3f3f46]',
}
const ratingBg: Record<string, string> = {
  essential: 'bg-accent-dim',
  good: 'bg-subtle',
  skip: 'bg-subtle',
}
---

<Base
  title="Books"
  description="Reading log with ratings and key takeaways."
>
  <section class="mx-auto max-w-[var(--container-grid)] px-5 pt-12 pb-24">
    <h1 class="text-3xl md:text-5xl mb-2">Books</h1>
    <p class="text-secondary/50 text-sm italic mb-10 max-w-md">
      "A book must be the axe for the frozen sea within us." — Kafka
    </p>

    {/* Currently reading */}
    {reading.length > 0 && (
      <div class="mb-12">
        <span class="text-xs font-[family-name:var(--font-mono)] text-secondary tracking-wider uppercase mb-4 block">
          Currently reading
        </span>
        {reading.map((book) => (
          <a
            href={`/books/${book.id}`}
            class="block rounded-lg border-l-2 border-accent bg-accent-dim p-5 hover:bg-[rgba(232,98,44,0.18)] transition-colors"
          >
            <div class="flex gap-5 items-start">
              <img
                src={book.data.cover}
                alt={`${book.data.title} by ${book.data.author}`}
                loading="lazy"
                decoding="async"
                class="w-32 object-cover rounded shrink-0"
                style="aspect-ratio: 2/3"
              />
              <div class="min-w-0">
                <h2 class="font-[family-name:var(--font-heading)] text-xl text-primary leading-snug">
                  {book.data.title}
                </h2>
                <p class="text-sm text-secondary mt-1">{book.data.author}</p>
                <p class="text-sm text-secondary/70 mt-2">{book.data.keyIdea}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

    {/* Book list */}
    <div id="book-list" class="space-y-0">
      {listed.map((book) => {
        const isDropped = book.data.status === 'dropped'
        const rating = book.data.rating
        return (
          <a
            href={`/books/${book.id}`}
            class:list={[
              'book-entry flex gap-4 py-4 border-b border-subtle hover:bg-surface/50 transition-all px-2 -mx-2 rounded',
              isDropped && 'opacity-40',
            ]}
            data-status={book.data.status}
          >
            <img
              src={book.data.cover}
              alt={`${book.data.title} by ${book.data.author}`}
              loading="lazy"
              decoding="async"
              class="w-12 h-18 object-cover rounded shrink-0"
              style="aspect-ratio: 2/3"
            />
            <div class="min-w-0 flex-1">
              <div class="flex items-baseline gap-2 flex-wrap">
                <h2 class="font-[family-name:var(--font-heading)] text-base text-primary leading-snug">
                  {book.data.title}
                </h2>
                {rating && (
                  <span class:list={[
                    'text-xs font-[family-name:var(--font-mono)] px-1.5 py-0.5 rounded',
                    ratingColor[rating],
                    ratingBg[rating],
                  ]}>
                    {rating}
                  </span>
                )}
                {isDropped && (
                  <span class="text-xs font-[family-name:var(--font-mono)] text-[#3f3f46]">
                    dropped
                  </span>
                )}
              </div>
              <p class="text-sm text-secondary">
                {book.data.author}
                <span class="text-[#3f3f46] mx-1">·</span>
                <span class="font-[family-name:var(--font-mono)] text-xs text-[#52525b]">{book.data.yearRead}</span>
              </p>
              <p class="text-sm text-secondary/70 mt-1 line-clamp-2">{book.data.keyIdea}</p>
            </div>
          </a>
        )
      })}
    </div>

    {books.length === 0 && (
      <p class="text-secondary text-center py-20">No books yet.</p>
    )}
  </section>
</Base>
