---
import Base from '../layouts/Base.astro'
import BuildCard from '../components/BuildCard.astro'
import Icon from '../components/Icon.astro'
import { builds, kindLabel } from '../data/builds'

const sorted = [...builds].sort((a, b) => a.position - b.position)
const hero = sorted.find((b) => b.status === 'active' && b.cover)
const active = sorted.filter((b) => b.status === 'active' && b !== hero)
const upcoming = sorted.filter((b) => b.status === 'soon')

const heroSince = hero?.startedOn
  ? new Date(hero.startedOn).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })
  : null
---

<Base
  title="Builds"
  description="Projects, tools, and communities I've built or contributed to."
>
  <section class="mx-auto max-w-[var(--container-grid)] px-5 pt-12 pb-24">
    <div class="build-fade" style="animation-delay: 0ms">
      <h1 class="text-4xl md:text-6xl mb-4">Builds</h1>
      <p class="text-secondary mb-12 max-w-xl">
        Projects, tools, and things I'm making.
      </p>
    </div>

    {/* ─── Hero — featured project ─── */}
    {hero && (
      <div class="build-fade mb-14" style="animation-delay: 60ms">
        <a
          href={hero.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block relative rounded-sm overflow-hidden transition-shadow duration-500 hover:shadow-[0_0_60px_rgba(232,98,44,0.06)]"
        >
          {/* Cover image */}
          <div class="aspect-[16/9] md:aspect-[21/9] overflow-hidden bg-base">
            <img
              src={hero.cover}
              alt={hero.title}
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.02]"
            />
          </div>

          {/* Gradient — fully opaque bottom half, clean fade to transparent */}
          <div class="absolute inset-0 hero-gradient" />

          {/* Content — positioned at bottom over the opaque part of gradient */}
          <div class="absolute bottom-0 left-0 right-0 p-6 md:p-10">
            {/* Kind + Status */}
            <div class="flex items-center gap-3 mb-3">
              <span class="font-[family-name:var(--font-mono)] text-[11px] text-[#71717a] tracking-wider uppercase">
                {kindLabel[hero.kind]}
              </span>
              <span class="text-[#3f3f46]">·</span>
              <span class="font-[family-name:var(--font-mono)] text-[11px] text-[#71717a]">
                {hero.status}
              </span>
            </div>

            {/* Title */}
            <h2 class="text-3xl md:text-5xl font-[family-name:var(--font-heading)] leading-tight text-primary group-hover:text-accent transition-colors duration-300 mb-3">
              {hero.title}
            </h2>

            {/* Description */}
            <p class="text-sm md:text-base max-w-xl mb-5 leading-relaxed" style="color: #a1a1aa">
              {hero.description}
            </p>

            {/* Stack + Since */}
            <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
              {hero.stack && hero.stack.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {hero.stack.map((tech) => (
                    <span class="font-[family-name:var(--font-mono)] text-[11px] text-[#71717a] bg-white/[0.06] px-2 py-0.5 rounded">
                      {tech}
                    </span>
                  ))}
                </div>
              )}
              {heroSince && (
                <>
                  <span class="text-[#3f3f46] hidden md:inline">·</span>
                  <span class="font-[family-name:var(--font-mono)] text-[11px] text-[#52525b]">
                    Since {heroSince}
                  </span>
                </>
              )}
            </div>
          </div>

          {/* Arrow */}
          <div class="absolute top-5 right-5 md:top-8 md:right-8 text-[#3f3f46] group-hover:text-accent transition-colors duration-300">
            <Icon name="arrow-up-right" size={20} />
          </div>
        </a>
      </div>
    )}

    {/* ─── Active projects ─── */}
    {active.length > 0 && (
      <div class="mb-16">
        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
          {active.map((build, i) => (
            <div class="build-fade" style={`animation-delay: ${120 + i * 80}ms`}>
              <BuildCard build={build} />
            </div>
          ))}
        </div>
      </div>
    )}

    {/* ─── On the horizon ─── */}
    {upcoming.length > 0 && (
      <div class="build-fade" style={`animation-delay: ${120 + active.length * 80 + 80}ms`}>
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-[family-name:var(--font-mono)] text-xs text-[#52525b] tracking-wider uppercase">On the horizon</h2>
          <div class="flex-1 h-px bg-subtle" />
        </div>

        <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
          {upcoming.map((build) => (
            <div class="group flex items-start gap-4 rounded-sm border border-white/[0.03] bg-card/50 p-5 transition-colors hover:bg-surface/50">
              <div class="flex-1 min-w-0">
                <h3 class="font-[family-name:var(--font-heading)] text-lg text-[#52525b] group-hover:text-secondary transition-colors leading-snug mb-1.5">
                  {build.title}
                </h3>
                <p class="text-sm text-[#3f3f46] leading-relaxed mb-3">
                  {build.description}
                </p>
                {build.stack && build.stack.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {build.stack.map((tech) => (
                      <span class="font-[family-name:var(--font-mono)] text-[10px] text-[#3f3f46] bg-subtle px-1.5 py-0.5 rounded">
                        {tech}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>

  <style>
    @keyframes build-fade-in {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .build-fade {
      animation: build-fade-in 0.6s ease both;
    }

    .hero-gradient {
      background: linear-gradient(
        to top,
        #09090b 0%,
        #09090b 25%,
        rgba(9, 9, 11, 0.95) 35%,
        rgba(9, 9, 11, 0.7) 50%,
        rgba(9, 9, 11, 0.3) 65%,
        transparent 80%
      );
    }
  </style>
</Base>
