---
import Base from '../layouts/Base.astro'
import BuildCard from '../components/BuildCard.astro'
import Icon from '../components/Icon.astro'
import { builds, kindLabel } from '../data/builds'

const sorted = [...builds].sort((a, b) => a.position - b.position)
const hero = sorted.find(b => b.status === 'active')
const active = sorted.filter(b => b.status === 'active' && b !== hero)
const upcoming = sorted.filter(b => b.status === 'soon')

const heroSince = hero?.startedOn
  ? new Date(hero.startedOn).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })
  : null
---

<Base
  title="Builds"
  description="Projects, tools, and communities I've built or contributed to."
>

  {/* ─── Page title ─── */}
  <div class="mx-auto max-w-[var(--container-grid)] px-5 pt-12 pb-10">
    <div class="build-fade" style="animation-delay: 0ms">
      <h1 class="text-4xl md:text-6xl mb-4">Builds</h1>
      <p class="text-secondary max-w-xl">Projects, tools, and things I'm making.</p>
    </div>
  </div>

  {/* ─── Hero — full-width dark strip ─── */}
  {hero && (
    <div class="hero-strip build-fade" style="animation-delay: 60ms">
      <div class="mx-auto max-w-[var(--container-grid)] px-5">

        {/* Meta */}
        <div class="hero-meta">
          <span class="hero-label">{kindLabel[hero.kind]}</span>
          <span class="hero-dot">·</span>
          <span class="hero-status-pill">{hero.status}</span>
          {heroSince && <span class="hero-since">Since {heroSince}</span>}
        </div>

        {/* Title */}
        <a
          href={hero.url}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-link group"
        >
          <h2 class="hero-title">{hero.title}</h2>
          <span class="hero-arrow"><Icon name="arrow-up-right" size={30} /></span>
        </a>

        {/* Description */}
        <p class="hero-desc">{hero.description}</p>

        {/* Stack */}
        {hero.stack && hero.stack.length > 0 && (
          <div class="hero-stack">
            {hero.stack.map(tech => (
              <span class="hero-tech">{tech}</span>
            ))}
          </div>
        )}

      </div>
      <div class="hero-accent-bar" />
    </div>
  )}

  {/* ─── Active projects ─── */}
  <section class="mx-auto max-w-[var(--container-grid)] px-5 pt-12 pb-24">

    {active.length > 0 && (
      <div class="mb-16">
        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
          {active.map((build, i) => (
            <div class="build-fade" style={`animation-delay: ${120 + i * 80}ms`}>
              <BuildCard build={build} />
            </div>
          ))}
        </div>
      </div>
    )}

    {/* ─── On the horizon ─── */}
    {upcoming.length > 0 && (
      <div class="build-fade" style={`animation-delay: ${120 + active.length * 80 + 80}ms`}>
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-[family-name:var(--font-mono)] text-xs text-[#8aa1a3] tracking-wider uppercase opacity-75">On the horizon</h2>
          <div class="flex-1 h-px bg-subtle" />
        </div>

        <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
          {upcoming.map((build) => (
            <div class="group flex items-start gap-4 rounded-sm border border-white/[0.03] bg-card/50 p-5 transition-colors hover:bg-surface/50">
              <div class="flex-1 min-w-0">
                <h3 class="font-[family-name:var(--font-heading)] text-lg text-[#52525b] group-hover:text-secondary transition-colors leading-snug mb-1.5">
                  {build.title}
                </h3>
                <p class="text-sm text-[#3f3f46] leading-relaxed mb-3">
                  {build.description}
                </p>
                {build.stack && build.stack.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {build.stack.map((tech) => (
                      <span class="font-[family-name:var(--font-mono)] text-[10px] text-[#3f3f46] bg-subtle px-1.5 py-0.5 rounded">
                        {tech}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </section>

  <style>
    @keyframes build-fade-in {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .build-fade {
      animation: build-fade-in 0.6s ease both;
    }

    /* ── Hero strip ── */
    .hero-strip {
      background: #111111;
      padding: 3.5rem 0 4.5rem;
      margin-bottom: 0;
      position: relative;
    }

    .hero-meta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 2rem;
    }

    .hero-label {
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #8aa1a3;
      opacity: 0.75;
    }

    .hero-dot {
      color: rgba(245, 239, 230, 0.12);
    }

    .hero-status-pill {
      font-family: var(--font-mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-accent);
      background: rgba(225, 87, 53, 0.12);
      padding: 2px 8px;
      border-radius: 2px;
    }

    .hero-since {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: 11px;
      color: rgba(245, 239, 230, 0.18);
    }

    .hero-link {
      display: inline-flex;
      align-items: flex-start;
      gap: 0.75rem;
      text-decoration: none;
      margin-bottom: 1.75rem;
    }

    .hero-title {
      font-family: var(--font-heading);
      font-size: clamp(3rem, 7vw, 6.5rem);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.0;
      color: #f5efe6;
      transition: color 0.25s;
    }

    .hero-link:hover .hero-title {
      color: var(--color-accent);
    }

    .hero-arrow {
      color: rgba(245, 239, 230, 0.18);
      margin-top: 0.6rem;
      flex-shrink: 0;
      transition: color 0.25s, transform 0.25s;
    }

    .hero-link:hover .hero-arrow {
      color: var(--color-accent);
      transform: translate(4px, -4px);
    }

    .hero-desc {
      color: rgba(245, 239, 230, 0.4);
      font-size: 1rem;
      max-width: 540px;
      line-height: 1.75;
      margin-bottom: 2rem;
    }

    .hero-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .hero-tech {
      font-family: var(--font-mono);
      font-size: 11px;
      color: rgba(245, 239, 230, 0.28);
      background: rgba(245, 239, 230, 0.05);
      border: 1px solid rgba(245, 239, 230, 0.07);
      padding: 3px 10px;
      border-radius: 2px;
      letter-spacing: 0.02em;
    }

    .hero-accent-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--color-terra);
    }
  </style>
</Base>
