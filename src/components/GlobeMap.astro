---
interface Location {
  slug: string
  title: string
  location: string
  lat: number
  lng: number
  year: number
}

interface Props {
  locations: Location[]
}

const { locations } = Astro.props
---

<div
  id="globe-container"
  class="relative w-full rounded-2xl border border-subtle overflow-hidden"
  style="height: clamp(320px, 60vh, 520px)"
  data-locations={JSON.stringify(locations)}
>
  <div id="globe" class="h-full w-full"></div>

  {/* Coordinates display */}
  <div
    id="globe-coords"
    class="absolute bottom-4 left-4 text-xs font-[family-name:var(--font-mono)] text-secondary/40 select-none pointer-events-none"
  ></div>

  {/* Zoom controls */}
  <div class="absolute bottom-3 right-3 flex flex-col gap-1 z-10">
    <button id="globe-zoom-in" class="map-zoom-btn" aria-label="Zoom in">+</button>
    <button id="globe-zoom-out" class="map-zoom-btn" aria-label="Zoom out">&minus;</button>
  </div>
</div>

<script>
  async function initGlobe() {
    const container = document.getElementById('globe-container')
    if (!container) return

    const maplibregl = await import('maplibre-gl')

    const link = document.createElement('link')
    link.rel = 'stylesheet'
    link.href = 'https://unpkg.com/maplibre-gl@latest/dist/maplibre-gl.css'
    document.head.appendChild(link)

    const locations: Array<{
      slug: string
      title: string
      location: string
      lat: number
      lng: number
      year: number
    }> = JSON.parse(container.dataset.locations || '[]')

    const map = new maplibregl.Map({
      container: 'globe',
      style: {
        version: 8,
        name: 'Fieldnotes Ink',
        sources: {
          'openfree': {
            type: 'vector',
            url: 'https://tiles.openfreemap.org/planet',
          },
        },
        glyphs: 'https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf',
        layers: [
          {
            id: 'background',
            type: 'background',
            paint: { 'background-color': '#18181b' },
          },
          {
            id: 'landcover',
            type: 'fill',
            source: 'openfree',
            'source-layer': 'landcover',
            paint: { 'fill-color': '#1f1f23', 'fill-opacity': 0.3 },
          },
          {
            id: 'landuse',
            type: 'fill',
            source: 'openfree',
            'source-layer': 'landuse',
            paint: { 'fill-color': '#1f1f23', 'fill-opacity': 0.3 },
          },
          {
            id: 'water',
            type: 'fill',
            source: 'openfree',
            'source-layer': 'water',
            paint: { 'fill-color': '#09090b' },
          },
          {
            id: 'waterway',
            type: 'line',
            source: 'openfree',
            'source-layer': 'waterway',
            paint: {
              'line-color': '#09090b',
              'line-width': ['interpolate', ['linear'], ['zoom'], 3, 0.5, 12, 2],
            },
          },
          {
            id: 'transportation',
            type: 'line',
            source: 'openfree',
            'source-layer': 'transportation',
            paint: {
              'line-color': '#27272a',
              'line-width': ['interpolate', ['linear'], ['zoom'], 5, 0.3, 12, 1.2],
            },
          },
          {
            id: 'boundary-country',
            type: 'line',
            source: 'openfree',
            'source-layer': 'boundary',
            filter: ['==', 'admin_level', 2],
            paint: {
              'line-color': '#3f3f46',
              'line-width': 1.2,
            },
          },
          {
            id: 'boundary-state',
            type: 'line',
            source: 'openfree',
            'source-layer': 'boundary',
            filter: ['==', 'admin_level', 4],
            paint: {
              'line-color': '#2e2e35',
              'line-width': 0.6,
              'line-dasharray': [6, 3],
            },
          },
          {
            id: 'water-name',
            type: 'symbol',
            source: 'openfree',
            'source-layer': 'water_name',
            layout: {
              'text-field': ['get', 'name'],
              'text-font': ['Noto Sans Italic'],
              'text-size': ['interpolate', ['linear'], ['zoom'], 3, 10, 8, 14],
              'text-letter-spacing': 0.15,
            },
            paint: {
              'text-color': '#27272e',
              'text-halo-color': '#09090b',
              'text-halo-width': 1.5,
            },
          },
          {
            id: 'place-country',
            type: 'symbol',
            source: 'openfree',
            'source-layer': 'place',
            filter: ['==', 'class', 'country'],
            layout: {
              'text-field': ['get', 'name'],
              'text-font': ['Noto Sans Regular'],
              'text-size': ['interpolate', ['linear'], ['zoom'], 2, 10, 6, 16],
              'text-transform': 'uppercase',
              'text-letter-spacing': 0.2,
            },
            paint: {
              'text-color': '#71717a',
              'text-halo-color': '#18181b',
              'text-halo-width': 2,
            },
          },
          {
            id: 'place-city',
            type: 'symbol',
            source: 'openfree',
            'source-layer': 'place',
            filter: ['in', 'class', 'city', 'town'],
            layout: {
              'text-field': ['get', 'name'],
              'text-font': ['Noto Sans Regular'],
              'text-size': ['interpolate', ['linear'], ['zoom'], 5, 10, 12, 14],
              'text-letter-spacing': 0.05,
            },
            paint: {
              'text-color': '#52525b',
              'text-halo-color': '#18181b',
              'text-halo-width': 2,
            },
          },
        ],
      },
      center: [40, 30],
      zoom: 1.8,
      attributionControl: false,
      pitchWithRotate: false,
    })

    map.scrollZoom.disable()

    map.on('load', () => {
      // Add location markers — store references for filtering
      const markers: Array<{ marker: any; el: HTMLElement; year: number }> = []

      locations.forEach((loc) => {
        const el = document.createElement('div')
        el.className = 'globe-marker'
        el.innerHTML = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="8" stroke="#e8622c" stroke-width="1" fill="none" opacity="0.4"/>
          <circle cx="12" cy="12" r="3" fill="#e8622c"/>
        </svg>`

        const marker = new maplibregl.Marker({ element: el })
          .setLngLat([loc.lng, loc.lat])
          .addTo(map)

        markers.push({ marker, el, year: loc.year })

        // Tooltip on hover
        const popup = new maplibregl.Popup({
          offset: 14,
          closeButton: false,
          closeOnClick: false,
          className: 'globe-popup',
        }).setHTML(`
          <div class="globe-popup-inner">
            <span class="globe-popup-title">${loc.title}</span>
            <span class="globe-popup-location">${loc.location}</span>
          </div>
        `)

        el.addEventListener('mouseenter', () => {
          marker.setPopup(popup)
          marker.togglePopup()
        })

        el.addEventListener('mouseleave', () => {
          popup.remove()
        })

        el.addEventListener('click', () => {
          map.flyTo({
            center: [loc.lng, loc.lat],
            zoom: 6,
            duration: 1200,
            easing: (t: number) => 1 - Math.pow(1 - t, 3),
          })
          setTimeout(() => {
            window.location.href = `/field/${loc.slug}`
          }, 800)
        })

        el.style.cursor = 'pointer'
      })

      // Listen for year filter events
      container.addEventListener('filter-year', ((e: CustomEvent) => {
        const year = e.detail.year
        markers.forEach(({ el, year: markerYear }) => {
          const show = year === 'all' || String(markerYear) === String(year)
          el.style.opacity = show ? '1' : '0.15'
          el.style.pointerEvents = show ? 'auto' : 'none'
        })
      }) as EventListener)

      // Zoom controls
      const zoomIn = document.getElementById('globe-zoom-in')
      const zoomOut = document.getElementById('globe-zoom-out')
      zoomIn?.addEventListener('click', () => map.zoomIn({ duration: 300 }))
      zoomOut?.addEventListener('click', () => map.zoomOut({ duration: 300 }))

      // Live coordinates display
      const coordsEl = document.getElementById('globe-coords')
      map.on('mousemove', (e) => {
        if (coordsEl) {
          const { lng, lat } = e.lngLat
          coordsEl.textContent = `${lat.toFixed(4)}° ${lng.toFixed(4)}°`
        }
      })
      map.on('mouseout', () => {
        if (coordsEl) coordsEl.textContent = ''
      })
    })
  }

  if (document.getElementById('globe-container')) {
    initGlobe()
  }
  document.addEventListener('astro:after-swap', () => {
    if (document.getElementById('globe-container')) {
      initGlobe()
    }
  })
</script>

<style is:global>
  .globe-marker {
    transition: transform 0.2s ease, opacity 0.4s ease;
    padding: 10px;
    margin: -10px;
  }

  .globe-marker:hover {
    transform: scale(1.25);
  }

  .globe-popup .maplibregl-popup-content {
    background: #18181b !important;
    border: 1px solid #27272a !important;
    border-radius: 0.5rem !important;
    padding: 10px 14px !important;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.5) !important;
  }

  .globe-popup .maplibregl-popup-tip {
    border-top-color: #27272a !important;
  }

  .globe-popup-inner {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .globe-popup-title {
    font-size: 13px;
    color: #d4d4d8;
    font-family: var(--font-heading);
    letter-spacing: 0.01em;
  }

  .globe-popup-location {
    font-size: 11px;
    color: #52525b;
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }

  /* Hide MapLibre cooperative gesture overlay */
  .maplibregl-cooperative-gesture-screen {
    display: none !important;
  }
</style>
