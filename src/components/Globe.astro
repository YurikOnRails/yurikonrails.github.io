---
interface MarkerData {
  id: string
  title: string
  location: string
  lat: number
  lng: number
  cover: string
}

interface Props {
  markers: MarkerData[]
}

const { markers } = Astro.props
---

<div class="relative w-full" style="aspect-ratio: 1 / 1; max-height: 560px;">
  <canvas id="globe-canvas" class="h-full w-full cursor-grab active:cursor-grabbing"></canvas>

  {/* Tooltip */}
  <div
    id="globe-tooltip"
    class="pointer-events-none absolute z-10 hidden rounded-xl border border-subtle bg-card/95 backdrop-blur-md shadow-2xl overflow-hidden transition-all duration-200"
    style="width: 220px;"
  >
    <div id="globe-tooltip-img" class="h-28 w-full bg-surface"></div>
    <div class="px-3 py-2.5">
      <p id="globe-tooltip-title" class="text-sm font-[family-name:var(--font-heading)] text-primary leading-snug"></p>
      <p id="globe-tooltip-location" class="text-xs text-secondary mt-0.5"></p>
    </div>
  </div>

  {/* Radial glow behind globe */}
  <div class="absolute inset-0 -z-10 opacity-30" style="background: radial-gradient(circle at 50% 50%, rgba(127,176,105,0.12) 0%, transparent 60%);"></div>
</div>

<script define:vars={{ markers }}>
  window.__globeMarkers = markers
</script>

<script>
  async function initGlobe() {
    const THREE = await import('three')

    const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement
    if (!canvas) return

    const markers: Array<{
      id: string
      title: string
      location: string
      lat: number
      lng: number
      cover: string
    }> = (window as any).__globeMarkers || []

    const tooltip = document.getElementById('globe-tooltip')!
    const tooltipTitle = document.getElementById('globe-tooltip-title')!
    const tooltipLocation = document.getElementById('globe-tooltip-location')!
    const tooltipImg = document.getElementById('globe-tooltip-img')!

    // --- Setup ---
    const container = canvas.parentElement!
    const width = container.clientWidth
    const height = container.clientHeight

    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
    })
    renderer.setSize(width, height)
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2))

    const scene = new THREE.Scene()
    const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000)
    camera.position.z = 2.8

    // --- Globe ---
    const globeRadius = 1

    // Atmosphere glow
    const atmosphereGeometry = new THREE.SphereGeometry(globeRadius * 1.015, 64, 64)
    const atmosphereMaterial = new THREE.ShaderMaterial({
      vertexShader: `
        varying vec3 vNormal;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        varying vec3 vNormal;
        void main() {
          float intensity = pow(0.65 - dot(vNormal, vec3(0.0, 0.0, 1.0)), 3.0);
          gl_FragColor = vec4(0.498, 0.69, 0.412, intensity * 0.4);
        }
      `,
      blending: THREE.AdditiveBlending,
      side: THREE.BackSide,
      transparent: true,
    })
    scene.add(new THREE.Mesh(atmosphereGeometry, atmosphereMaterial))

    // Globe sphere — dark with subtle grid
    const globeGeometry = new THREE.SphereGeometry(globeRadius, 64, 64)
    const globeMaterial = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color('#0a120e') },
        uLineColor: { value: new THREE.Color('#1a2e22') },
        uAccent: { value: new THREE.Color('#7fb069') },
      },
      vertexShader: `
        varying vec3 vNormal;
        varying vec3 vPosition;
        varying vec2 vUv;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          vPosition = position;
          vUv = uv;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        uniform vec3 uLineColor;
        uniform vec3 uAccent;
        varying vec3 vNormal;
        varying vec3 vPosition;
        varying vec2 vUv;

        void main() {
          // Fresnel rim light
          float fresnel = pow(1.0 - abs(dot(vNormal, vec3(0.0, 0.0, 1.0))), 2.5);

          // Grid lines
          float lat = vUv.y * 3.14159;
          float lng = vUv.x * 6.28318;

          float latLine = smoothstep(0.015, 0.005, abs(fract(vUv.y * 18.0) - 0.5) - 0.48);
          float lngLine = smoothstep(0.015, 0.005, abs(fract(vUv.x * 36.0) - 0.5) - 0.48);
          float grid = max(latLine, lngLine) * 0.3;

          vec3 color = mix(uColor, uLineColor, grid);
          color = mix(color, uAccent, fresnel * 0.25);

          // Subtle top lighting
          float topLight = max(dot(vNormal, normalize(vec3(0.3, 1.0, 0.5))), 0.0) * 0.15;
          color += topLight * uAccent * 0.3;

          gl_FragColor = vec4(color, 1.0);
        }
      `,
    })
    const globe = new THREE.Mesh(globeGeometry, globeMaterial)
    scene.add(globe)

    // --- Markers ---
    const markerGroup = new THREE.Group()
    scene.add(markerGroup)

    interface MarkerMesh extends THREE.Mesh {
      userData: {
        id: string
        title: string
        location: string
        cover: string
        baseScale: number
      }
    }

    function latLngToVector3(lat: number, lng: number, radius: number): THREE.Vector3 {
      const phi = (90 - lat) * (Math.PI / 180)
      const theta = (lng + 180) * (Math.PI / 180)
      return new THREE.Vector3(
        -radius * Math.sin(phi) * Math.cos(theta),
        radius * Math.cos(phi),
        radius * Math.sin(phi) * Math.sin(theta)
      )
    }

    const markerGeometry = new THREE.SphereGeometry(0.018, 16, 16)

    // Glow ring around each marker
    const ringGeometry = new THREE.RingGeometry(0.025, 0.04, 32)

    markers.forEach((m) => {
      const pos = latLngToVector3(m.lat, m.lng, globeRadius)

      // Marker dot
      const markerMaterial = new THREE.MeshBasicMaterial({ color: '#7fb069' })
      const markerMesh = new THREE.Mesh(markerGeometry, markerMaterial) as MarkerMesh
      markerMesh.position.copy(pos)
      markerMesh.userData = {
        id: m.id,
        title: m.title,
        location: m.location,
        cover: m.cover,
        baseScale: 1,
      }
      markerGroup.add(markerMesh)

      // Pulsing glow ring
      const ringMaterial = new THREE.MeshBasicMaterial({
        color: '#7fb069',
        transparent: true,
        opacity: 0.3,
        side: THREE.DoubleSide,
      })
      const ring = new THREE.Mesh(ringGeometry, ringMaterial)
      ring.position.copy(pos)
      ring.lookAt(new THREE.Vector3(0, 0, 0))
      ring.userData = { isRing: true, phase: Math.random() * Math.PI * 2 }
      markerGroup.add(ring)
    })

    // --- Interaction ---
    const raycaster = new THREE.Raycaster()
    const mouse = new THREE.Vector2()
    let hoveredMarker: MarkerMesh | null = null
    let isHovering = false
    let isDragging = false
    let previousMouse = { x: 0, y: 0 }
    let autoRotateSpeed = 0.002
    let targetRotationX = 0
    let targetRotationY = 0

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect()
      mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1
      mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1

      if (isDragging) {
        const dx = e.clientX - previousMouse.x
        const dy = e.clientY - previousMouse.y
        targetRotationY += dx * 0.005
        targetRotationX += dy * 0.005
        targetRotationX = Math.max(-Math.PI / 3, Math.min(Math.PI / 3, targetRotationX))
        previousMouse = { x: e.clientX, y: e.clientY }
      }

      // Raycast markers
      raycaster.setFromCamera(mouse, camera)
      const markerMeshes = markerGroup.children.filter(
        (c) => !(c as any).userData.isRing
      )
      const intersects = raycaster.intersectObjects(markerMeshes)

      if (intersects.length > 0) {
        const hit = intersects[0].object as MarkerMesh
        if (hoveredMarker !== hit) {
          hoveredMarker = hit
          isHovering = true
          canvas.style.cursor = 'pointer'

          // Update tooltip
          tooltipTitle.textContent = hit.userData.title
          tooltipLocation.textContent = hit.userData.location
          tooltipImg.style.backgroundImage = `url(${hit.userData.cover})`
          tooltipImg.style.backgroundSize = 'cover'
          tooltipImg.style.backgroundPosition = 'center'
          tooltip.classList.remove('hidden')
        }

        // Position tooltip
        const screenPos = hit.position.clone().applyMatrix4(globe.matrixWorld)
        screenPos.project(camera)
        const x = ((screenPos.x + 1) / 2) * width
        const y = ((-screenPos.y + 1) / 2) * height
        tooltip.style.left = `${x + 16}px`
        tooltip.style.top = `${y - 60}px`
      } else {
        if (hoveredMarker) {
          hoveredMarker = null
          isHovering = false
          canvas.style.cursor = 'grab'
          tooltip.classList.add('hidden')
        }
      }
    })

    canvas.addEventListener('mousedown', (e) => {
      isDragging = true
      previousMouse = { x: e.clientX, y: e.clientY }
      canvas.style.cursor = 'grabbing'
    })

    canvas.addEventListener('mouseup', () => {
      isDragging = false
      canvas.style.cursor = isHovering ? 'pointer' : 'grab'
    })

    canvas.addEventListener('mouseleave', () => {
      isDragging = false
      isHovering = false
      hoveredMarker = null
      tooltip.classList.add('hidden')
      canvas.style.cursor = 'grab'
    })

    canvas.addEventListener('click', () => {
      if (hoveredMarker) {
        window.location.href = `/field/${hoveredMarker.userData.id}`
      }
    })

    // Touch support
    let touchStart = { x: 0, y: 0 }
    canvas.addEventListener('touchstart', (e) => {
      const t = e.touches[0]
      touchStart = { x: t.clientX, y: t.clientY }
      isDragging = true
      previousMouse = { x: t.clientX, y: t.clientY }
    }, { passive: true })

    canvas.addEventListener('touchmove', (e) => {
      const t = e.touches[0]
      const dx = t.clientX - previousMouse.x
      const dy = t.clientY - previousMouse.y
      targetRotationY += dx * 0.005
      targetRotationX += dy * 0.005
      targetRotationX = Math.max(-Math.PI / 3, Math.min(Math.PI / 3, targetRotationX))
      previousMouse = { x: t.clientX, y: t.clientY }
    }, { passive: true })

    canvas.addEventListener('touchend', () => {
      isDragging = false
    })

    // --- Resize ---
    const resizeObserver = new ResizeObserver(() => {
      const w = container.clientWidth
      const h = container.clientHeight
      renderer.setSize(w, h)
      camera.aspect = w / h
      camera.updateProjectionMatrix()
    })
    resizeObserver.observe(container)

    // --- Animate ---
    let time = 0
    function animate() {
      requestAnimationFrame(animate)
      time += 0.01

      // Auto-rotate (slows on hover/drag)
      if (!isDragging && !isHovering) {
        targetRotationY += autoRotateSpeed
      }

      globe.rotation.x += (targetRotationX - globe.rotation.x) * 0.05
      globe.rotation.y += (targetRotationY - globe.rotation.y) * 0.05
      markerGroup.rotation.x = globe.rotation.x
      markerGroup.rotation.y = globe.rotation.y

      // Pulse rings
      markerGroup.children.forEach((child) => {
        if ((child as any).userData.isRing) {
          const phase = (child as any).userData.phase
          const scale = 1 + Math.sin(time * 2 + phase) * 0.3
          child.scale.set(scale, scale, scale)
          ;(child as THREE.Mesh).material && ((child as THREE.Mesh).material as THREE.MeshBasicMaterial).opacity !== undefined &&
            (((child as THREE.Mesh).material as THREE.MeshBasicMaterial).opacity = 0.2 + Math.sin(time * 2 + phase) * 0.15)
        }
      })

      renderer.render(scene, camera)
    }

    animate()
  }

  // Initialize on load and after view transitions
  if (document.getElementById('globe-canvas')) {
    initGlobe()
  }
  document.addEventListener('astro:after-swap', () => {
    if (document.getElementById('globe-canvas')) {
      initGlobe()
    }
  })
</script>
