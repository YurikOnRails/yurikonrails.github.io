---
import Icon from './Icon.astro'
import type { Build } from '../data/builds'

interface Props {
  build: Build
}

const { build } = Astro.props
const { title, description, url, icon, status } = build

const statusColors: Record<string, string> = {
  active: 'bg-accent/20 text-accent',
  paused: 'bg-yellow-500/20 text-yellow-400',
  completed: 'bg-blue-500/20 text-blue-400',
  archived: 'bg-secondary/20 text-secondary',
}
---

<article class="card group">
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="flex flex-col rounded-2xl border border-subtle bg-card p-5 md:p-6 transition-colors hover:bg-surface h-full"
  >
    <div class="flex items-start justify-between gap-3 mb-3">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-accent-dim text-accent">
          <Icon name={icon} size={20} />
        </div>
        <h2 class="text-lg font-[family-name:var(--font-heading)] group-hover:text-accent transition-colors">
          {title}
        </h2>
      </div>
      <span class:list={['shrink-0 rounded-full px-2.5 py-0.5 text-xs', statusColors[status]]}>
        {status}
      </span>
    </div>
    <p class="text-sm text-secondary leading-relaxed flex-1">
      {description}
    </p>
  </a>
</article>
