---
import type { Build } from '../data/builds'
import { kindLabel } from '../data/builds'
import Icon from './Icon.astro'

interface Props {
  build: Build
}

const { build } = Astro.props
const { title, description, url, status, kind, stack = [], startedOn } = build

const statusStyle: Record<string, string> = {
  active: 'text-accent bg-accent-dim',
  paused: 'text-yellow-400 bg-yellow-500/20',
  completed: 'text-blue-400 bg-blue-500/20',
  archived: 'text-secondary bg-secondary/20',
}

const sinceStr = startedOn
  ? new Date(startedOn).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })
  : null
---

<article class="group h-full">
  <div class="build-card relative flex flex-col rounded-sm border border-white/[0.04] bg-card p-6 md:p-8 transition-all duration-300 h-full overflow-hidden hover:bg-surface hover:border-[#3f3f46] hover:shadow-[0_0_40px_rgba(232,98,44,0.06)] cursor-pointer">

    {/* Clickable overlay */}
    {url && (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="absolute inset-0 z-10"
        aria-label={title}
      />
    )}

    {/* Top stripe */}
    <div class="absolute top-0 left-0 right-0 h-[1px] bg-white/[0.06]" />

    {/* Header: kind + status */}
    <div class="flex items-center justify-between gap-3 mb-4">
      <span class="font-[family-name:var(--font-mono)] text-[11px] text-[#52525b] tracking-wider uppercase">
        {kindLabel[kind]}
      </span>
      <span class:list={[
        'font-[family-name:var(--font-mono)] text-xs px-2 py-0.5 rounded shrink-0',
        statusStyle[status],
      ]}>
        {status}
      </span>
    </div>

    {/* Title with external link icon */}
    <div class="flex items-start gap-2 mb-3">
      <h2 class="text-xl font-[family-name:var(--font-heading)] transition-colors leading-snug text-primary group-hover:text-accent">
        {title}
      </h2>
      {url && (
        <span class="shrink-0 mt-1 text-[#3f3f46] group-hover:text-accent transition-all duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
          <Icon name="arrow-up-right" size={16} />
        </span>
      )}
    </div>

    {/* Description */}
    <p class="text-sm text-secondary leading-relaxed flex-1 mb-5">
      {description}
    </p>

    {/* Stack badges */}
    {stack.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-4">
        {stack.map((tech) => (
          <span class="font-[family-name:var(--font-mono)] text-[11px] text-[#52525b] bg-subtle px-2 py-0.5 rounded">
            {tech}
          </span>
        ))}
      </div>
    )}

    {/* Footer: since date */}
    {sinceStr && (
      <div class="pt-4 border-t border-subtle">
        <span class="font-[family-name:var(--font-mono)] text-[11px] text-[#3f3f46]">
          Since {sinceStr}
        </span>
      </div>
    )}
  </div>
</article>
