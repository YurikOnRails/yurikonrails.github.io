---
interface PhotoMarker {
  src: string
  caption?: string
  index: number
}

interface Props {
  lat: number
  lng: number
  title: string
  photos?: PhotoMarker[]
}

const { lat, lng, title, photos = [] } = Astro.props
---

<div
  id="map-container"
  class="relative h-64 md:h-80 rounded-2xl border border-subtle overflow-hidden"
  data-lat={lat}
  data-lng={lng}
  data-title={title}
  data-photos={JSON.stringify(photos)}
>
  <div id="map" class="h-full w-full"></div>

  {/* Zoom controls */}
  <div class="absolute bottom-3 right-3 flex flex-col gap-1 z-10">
    <button id="map-zoom-in" class="map-zoom-btn" aria-label="Zoom in">+</button>
    <button id="map-zoom-out" class="map-zoom-btn" aria-label="Zoom out">&minus;</button>
  </div>

</div>

<script>
  async function initMap() {
    const container = document.getElementById('map-container')
    if (!container) return

    const maplibregl = await import('maplibre-gl')

    const link = document.createElement('link')
    link.rel = 'stylesheet'
    link.href = 'https://unpkg.com/maplibre-gl@latest/dist/maplibre-gl.css'
    document.head.appendChild(link)

    const lat = parseFloat(container.dataset.lat || '0')
    const lng = parseFloat(container.dataset.lng || '0')
    const title = container.dataset.title || ''
    const photos: Array<{ src: string; caption?: string; index: number }> = JSON.parse(
      container.dataset.photos || '[]'
    )

    const map = new maplibregl.Map({
      container: 'map',
      style: {
        version: 8,
        name: 'Fieldnotes Ink',
        sources: {
          'openfree': {
            type: 'vector',
            url: 'https://tiles.openfreemap.org/planet',
          },
        },
        glyphs: 'https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf',
        layers: [
          // Background = land
          {
            id: 'background',
            type: 'background',
            paint: { 'background-color': '#18181b' },
          },
          // Landcover (forest, grass, sand)
          {
            id: 'landcover',
            type: 'fill',
            source: 'openfree',
            'source-layer': 'landcover',
            paint: { 'fill-color': '#1f1f23', 'fill-opacity': 0.3 },
          },
          // Landuse (residential, industrial, etc)
          {
            id: 'landuse',
            type: 'fill',
            source: 'openfree',
            'source-layer': 'landuse',
            paint: { 'fill-color': '#1f1f23', 'fill-opacity': 0.3 },
          },
          // Water (oceans, lakes)
          {
            id: 'water',
            type: 'fill',
            source: 'openfree',
            'source-layer': 'water',
            paint: { 'fill-color': '#09090b' },
          },
          // Rivers, streams
          {
            id: 'waterway',
            type: 'line',
            source: 'openfree',
            'source-layer': 'waterway',
            paint: {
              'line-color': '#09090b',
              'line-width': ['interpolate', ['linear'], ['zoom'], 3, 0.5, 12, 2],
            },
          },
          // Roads
          {
            id: 'transportation',
            type: 'line',
            source: 'openfree',
            'source-layer': 'transportation',
            paint: {
              'line-color': '#27272a',
              'line-width': ['interpolate', ['linear'], ['zoom'], 5, 0.3, 12, 1.2],
            },
          },
          // Country & state borders
          {
            id: 'boundary-country',
            type: 'line',
            source: 'openfree',
            'source-layer': 'boundary',
            filter: ['==', 'admin_level', 2],
            paint: {
              'line-color': '#3f3f46',
              'line-width': 1.2,
            },
          },
          {
            id: 'boundary-state',
            type: 'line',
            source: 'openfree',
            'source-layer': 'boundary',
            filter: ['==', 'admin_level', 4],
            paint: {
              'line-color': '#2e2e35',
              'line-width': 0.6,
              'line-dasharray': [6, 3],
            },
          },
          // Water labels
          {
            id: 'water-name',
            type: 'symbol',
            source: 'openfree',
            'source-layer': 'water_name',
            layout: {
              'text-field': ['get', 'name'],
              'text-font': ['Noto Sans Italic'],
              'text-size': ['interpolate', ['linear'], ['zoom'], 3, 10, 8, 14],
              'text-letter-spacing': 0.15,
            },
            paint: {
              'text-color': '#27272e',
              'text-halo-color': '#09090b',
              'text-halo-width': 1.5,
            },
          },
          // Place labels
          {
            id: 'place-country',
            type: 'symbol',
            source: 'openfree',
            'source-layer': 'place',
            filter: ['==', 'class', 'country'],
            layout: {
              'text-field': ['get', 'name'],
              'text-font': ['Noto Sans Regular'],
              'text-size': ['interpolate', ['linear'], ['zoom'], 2, 10, 6, 16],
              'text-transform': 'uppercase',
              'text-letter-spacing': 0.2,
            },
            paint: {
              'text-color': '#71717a',
              'text-halo-color': '#18181b',
              'text-halo-width': 2,
            },
          },
          {
            id: 'place-city',
            type: 'symbol',
            source: 'openfree',
            'source-layer': 'place',
            filter: ['in', 'class', 'city', 'town'],
            layout: {
              'text-field': ['get', 'name'],
              'text-font': ['Noto Sans Regular'],
              'text-size': ['interpolate', ['linear'], ['zoom'], 5, 10, 12, 14],
              'text-letter-spacing': 0.05,
            },
            paint: {
              'text-color': '#52525b',
              'text-halo-color': '#18181b',
              'text-halo-width': 2,
            },
          },
        ],
      },
      center: [lng, lat],
      zoom: 7,
      attributionControl: false,
      pitchWithRotate: false,
      cooperativeGestures: true,
    })

    map.on('load', () => {
      const el = document.createElement('div')
      el.className = 'map-marker-main'
      el.innerHTML = `
        <div style="
          width: 12px; height: 12px;
          background: #e8622c;
          border-radius: 50%;
          border: 2px solid #18181b;
          position: relative;
        ">
          <div style="
            position: absolute; inset: -6px;
            border: 1.5px solid rgba(232,98,44,0.35);
            border-radius: 50%;
          "></div>
        </div>
      `

      new maplibregl.Marker({ element: el })
        .setLngLat([lng, lat])
        .setPopup(
          new maplibregl.Popup({
            offset: 16,
            closeButton: false,
            className: 'fieldnotes-popup',
          }).setHTML(`<span style="font-size:13px;color:#fafafa;">${title}</span>`)
        )
        .addTo(map)

      if (photos.length > 1) {
        photos.forEach((photo, i) => {
          const angle = (i / photos.length) * Math.PI * 2
          const radius = 0.015 + Math.random() * 0.01
          const pLat = lat + Math.cos(angle) * radius
          const pLng = lng + Math.sin(angle) * radius

          const photoEl = document.createElement('div')
          photoEl.style.cssText = `
            width: 7px; height: 7px;
            background: #e8622c;
            border-radius: 50%;
            border: 1.5px solid #18181b;
            cursor: pointer;
            opacity: 0.6;
            transition: opacity 0.15s;
          `
          photoEl.addEventListener('mouseenter', () => {
            photoEl.style.opacity = '1'
          })
          photoEl.addEventListener('mouseleave', () => {
            photoEl.style.opacity = '0.6'
          })
          photoEl.addEventListener('click', () => {
            const photoEls = document.querySelectorAll('figure')
            if (photoEls[photo.index]) {
              photoEls[photo.index].scrollIntoView({ behavior: 'smooth', block: 'center' })
            }
          })

          new maplibregl.Marker({ element: photoEl })
            .setLngLat([pLng, pLat])
            .addTo(map)
        })
      }

      const zoomIn = document.getElementById('map-zoom-in')
      const zoomOut = document.getElementById('map-zoom-out')
      zoomIn?.addEventListener('click', () => map.zoomIn({ duration: 300 }))
      zoomOut?.addEventListener('click', () => map.zoomOut({ duration: 300 }))

      map.flyTo({
        center: [lng, lat],
        zoom: 9,
        duration: 2400,
        curve: 1.4,
        easing: (t: number) => 1 - Math.pow(1 - t, 3),
      })
    })
  }

  if (document.getElementById('map-container')) {
    initMap()
  }
  document.addEventListener('astro:after-swap', () => {
    if (document.getElementById('map-container')) {
      initMap()
    }
  })
</script>

<style is:global>
  .maplibregl-popup-content {
    background: #18181b !important;
    border: 1px solid #3a3c48 !important;
    border-radius: 0.5rem !important;
    padding: 6px 10px !important;
    box-shadow: none !important;
  }

  .maplibregl-popup-tip {
    border-top-color: #18181b !important;
  }

  .maplibregl-ctrl-attrib {
    display: none !important;
  }

  .map-zoom-btn {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    border: 1px solid #3a3c48;
    background: #18181b;
    color: #71717a;
    font-size: 15px;
    font-family: var(--font-mono);
    line-height: 1;
    cursor: pointer;
    transition: color 0.15s;
  }

  .map-zoom-btn:hover {
    color: #fafafa;
  }
</style>
