---
interface PhotoMarker {
  src: string
  caption?: string
  index: number
}

interface Props {
  lat: number
  lng: number
  title: string
  photos?: PhotoMarker[]
}

const { lat, lng, title, photos = [] } = Astro.props
---

<div
  id="map-container"
  class="relative h-64 md:h-80 rounded-2xl border border-subtle overflow-hidden"
  data-lat={lat}
  data-lng={lng}
  data-title={title}
  data-photos={JSON.stringify(photos)}
>
  <div id="map" class="h-full w-full"></div>

  {/* Gradient fade edges */}
  <div class="pointer-events-none absolute inset-0 rounded-2xl" style="box-shadow: inset 0 0 40px 20px var(--color-base);"></div>
</div>

<script>
  async function initMap() {
    const container = document.getElementById('map-container')
    if (!container) return

    const maplibregl = await import('maplibre-gl')

    const link = document.createElement('link')
    link.rel = 'stylesheet'
    link.href = 'https://unpkg.com/maplibre-gl@latest/dist/maplibre-gl.css'
    document.head.appendChild(link)

    const lat = parseFloat(container.dataset.lat || '0')
    const lng = parseFloat(container.dataset.lng || '0')
    const title = container.dataset.title || ''
    const photos: Array<{ src: string; caption?: string; index: number }> = JSON.parse(
      container.dataset.photos || '[]'
    )

    const map = new maplibregl.Map({
      container: 'map',
      style: {
        version: 8,
        name: 'Fieldnotes Ember',
        sources: {
          'openfree': {
            type: 'vector',
            url: 'https://tiles.openfreemap.org/planet',
          },
        },
        glyphs: 'https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf',
        layers: [
          {
            id: 'background',
            type: 'background',
            paint: { 'background-color': '#0a0908' },
          },
          {
            id: 'water',
            type: 'fill',
            source: 'openfree',
            'source-layer': 'water',
            paint: { 'fill-color': '#0c0a08' },
          },
          {
            id: 'earth',
            type: 'fill',
            source: 'openfree',
            'source-layer': 'earth',
            paint: { 'fill-color': '#13100e' },
          },
          {
            id: 'landuse',
            type: 'fill',
            source: 'openfree',
            'source-layer': 'landuse',
            paint: { 'fill-color': '#181412', 'fill-opacity': 0.6 },
          },
          {
            id: 'roads',
            type: 'line',
            source: 'openfree',
            'source-layer': 'roads',
            filter: ['in', 'kind', 'highway', 'major_road'],
            paint: {
              'line-color': '#2a211c',
              'line-width': ['interpolate', ['linear'], ['zoom'], 5, 0.3, 12, 1.5],
              'line-opacity': 0.5,
            },
          },
          {
            id: 'boundaries',
            type: 'line',
            source: 'openfree',
            'source-layer': 'boundaries',
            paint: {
              'line-color': '#2a211c',
              'line-width': 0.5,
              'line-dasharray': [4, 4],
              'line-opacity': 0.4,
            },
          },
          {
            id: 'places',
            type: 'symbol',
            source: 'openfree',
            'source-layer': 'places',
            filter: ['in', 'kind', 'country', 'state', 'city'],
            layout: {
              'text-field': ['get', 'name'],
              'text-font': ['Noto Sans Regular'],
              'text-size': ['interpolate', ['linear'], ['zoom'], 3, 10, 8, 13],
              'text-transform': 'uppercase',
              'text-letter-spacing': 0.1,
            },
            paint: {
              'text-color': '#4a3d35',
              'text-halo-color': '#0a0908',
              'text-halo-width': 1.5,
            },
          },
        ],
      },
      center: [lng, lat],
      zoom: 7,
      attributionControl: false,
      pitchWithRotate: false,
    })

    map.scrollZoom.disable()

    map.on('load', () => {
      const el = document.createElement('div')
      el.className = 'map-marker-main'
      el.innerHTML = `
        <div style="
          width: 16px; height: 16px;
          background: #c45d3e;
          border-radius: 50%;
          box-shadow: 0 0 12px 4px rgba(196,93,62,0.4), 0 0 24px 8px rgba(196,93,62,0.15);
          position: relative;
        ">
          <div style="
            position: absolute; inset: -8px;
            border: 1.5px solid rgba(196,93,62,0.3);
            border-radius: 50%;
            animation: map-pulse 2.5s ease-out infinite;
          "></div>
        </div>
      `

      new maplibregl.Marker({ element: el })
        .setLngLat([lng, lat])
        .setPopup(
          new maplibregl.Popup({
            offset: 16,
            closeButton: false,
            className: 'fieldnotes-popup',
          }).setHTML(`<span style="font-size:13px;color:#e5ddd3;">${title}</span>`)
        )
        .addTo(map)

      if (photos.length > 1) {
        photos.forEach((photo, i) => {
          const angle = (i / photos.length) * Math.PI * 2
          const radius = 0.015 + Math.random() * 0.01
          const pLat = lat + Math.cos(angle) * radius
          const pLng = lng + Math.sin(angle) * radius

          const photoEl = document.createElement('div')
          photoEl.style.cssText = `
            width: 8px; height: 8px;
            background: rgba(196,93,62,0.6);
            border-radius: 50%;
            border: 1px solid rgba(196,93,62,0.3);
            cursor: pointer;
            transition: all 0.2s;
          `
          photoEl.addEventListener('mouseenter', () => {
            photoEl.style.transform = 'scale(1.8)'
            photoEl.style.background = '#c45d3e'
          })
          photoEl.addEventListener('mouseleave', () => {
            photoEl.style.transform = 'scale(1)'
            photoEl.style.background = 'rgba(196,93,62,0.6)'
          })
          photoEl.addEventListener('click', () => {
            const photoEls = document.querySelectorAll('figure')
            if (photoEls[photo.index]) {
              photoEls[photo.index].scrollIntoView({ behavior: 'smooth', block: 'center' })
            }
          })

          new maplibregl.Marker({ element: photoEl })
            .setLngLat([pLng, pLat])
            .addTo(map)
        })
      }

      map.flyTo({
        center: [lng, lat],
        zoom: 9,
        duration: 2400,
        curve: 1.4,
        easing: (t: number) => 1 - Math.pow(1 - t, 3),
      })
    })
  }

  if (document.getElementById('map-container')) {
    initMap()
  }
  document.addEventListener('astro:after-swap', () => {
    if (document.getElementById('map-container')) {
      initMap()
    }
  })
</script>

<style is:global>
  @keyframes map-pulse {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(3); opacity: 0; }
  }

  .maplibregl-popup-content {
    background: #1a1614 !important;
    border: 1px solid rgba(196,93,62,0.08) !important;
    border-radius: 0.75rem !important;
    padding: 8px 12px !important;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4) !important;
  }

  .maplibregl-popup-tip {
    border-top-color: #1a1614 !important;
  }

  .maplibregl-ctrl-attrib {
    display: none !important;
  }
</style>
