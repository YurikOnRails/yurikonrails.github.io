---
interface Props {
  name: string
  size?: number
  class?: string
}

const { name, size = 24, class: className = '' } = Astro.props

const icons = import.meta.glob<string>('/src/icons/*.svg', { query: '?raw', import: 'default', eager: true })
const key = `/src/icons/${name}.svg`
const svg = icons[key]
---

{svg && (
  <span
    class:list={['inline-flex shrink-0 items-center justify-center', className]}
    style={`width:${size}px;height:${size}px`}
    set:html={svg}
    aria-hidden="true"
  />
)}
