---
import Icon from './Icon.astro'
import { navLinks } from '../data/navigation'
import { profile } from '../data/profile'

const currentPath = Astro.url.pathname
const [logoFirst, logoLast] = profile.name.toUpperCase().split(' ')
---

<header id="main-header" class="site-header">
  <nav
    class="mx-auto flex max-w-[var(--container-grid)] items-center justify-between px-5 py-3 md:py-4"
    aria-label="Main navigation"
  >
    <a href="/" class="logo-link">
      <span class="logo-first">{logoFirst}</span>
      <span class="logo-sep"> · </span>
      <span class="logo-last">{logoLast}</span>
    </a>

    {/* Desktop nav */}
    <ul class="hidden md:flex items-center gap-7">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav-link', currentPath.startsWith(href) ? 'nav-link--active' : '']}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    {/* Mobile toggle — burger / close */}
    <button
      id="menu-toggle"
      class="md:hidden relative flex items-center justify-center w-11 h-11 -mr-2 text-white/50 hover:text-white transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="toggle-icon-menu"><Icon name="menu" size={22} /></span>
      <span class="toggle-icon-close"><Icon name="x" size={22} /></span>
    </button>
  </nav>

  <div class="header-accent" />
</header>

{/* ── Mobile slide-down panel ── */}
<div id="mobile-panel" class="mobile-panel" aria-hidden="true">
  <ul class="px-5 pt-2 pb-5">
    {navLinks.map(({ href, label }) => (
      <li class="panel-item">
        <a
          href={href}
          class:list={[
            'panel-link',
            currentPath.startsWith(href) ? 'panel-link--active' : '',
          ]}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</div>

{/* Backdrop */}
<div id="panel-backdrop" class="panel-backdrop" />

{/* Spacer */}
<div class="h-[52px] md:h-[62px]" />

<script>
  let scrollAbort = new AbortController()

  function initHeader() {
    const header   = document.getElementById('main-header')
    const panel    = document.getElementById('mobile-panel')
    const backdrop = document.getElementById('panel-backdrop')
    const toggle   = document.getElementById('menu-toggle')

    if (!header || !panel || !backdrop || !toggle) return

    let isOpen    = false
    let lastY     = window.scrollY
    let ticking   = false

    // ── Auto-hide on scroll ──
    scrollAbort.abort()
    scrollAbort = new AbortController()

    function onScroll() {
      if (ticking) return
      ticking = true

      requestAnimationFrame(() => {
        const y = window.scrollY

        if (!isOpen) {
          if (y <= 10) {
            header.classList.remove('header--hidden')
          } else if (y > lastY + 8) {
            header.classList.add('header--hidden')
          } else if (y < lastY - 4) {
            header.classList.remove('header--hidden')
          }
        }

        lastY    = y
        ticking  = false
      })
    }

    window.addEventListener('scroll', onScroll, {
      passive: true,
      signal: scrollAbort.signal,
    })

    // ── Open / close ──
    function openMenu() {
      if (isOpen) return
      isOpen = true

      header.classList.remove('header--hidden')
      toggle.setAttribute('aria-expanded', 'true')
      toggle.classList.add('is-open')
      panel.classList.add('is-open')
      panel.setAttribute('aria-hidden', 'false')
      backdrop.classList.add('is-visible')
      document.body.style.overflow = 'hidden'
    }

    function closeMenu() {
      if (!isOpen) return
      isOpen = false

      toggle.setAttribute('aria-expanded', 'false')
      toggle.classList.remove('is-open')
      panel.classList.remove('is-open')
      panel.setAttribute('aria-hidden', 'true')
      backdrop.classList.remove('is-visible')
      document.body.style.overflow = ''
    }

    toggle.addEventListener('click', () => (isOpen ? closeMenu() : openMenu()))
    backdrop.addEventListener('click', closeMenu)
    panel.querySelectorAll('.panel-link').forEach((l) => l.addEventListener('click', closeMenu))
  }

  initHeader()
  document.addEventListener('astro:after-swap', initHeader)
</script>

<style>
  /* ── Header ── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(17, 17, 17, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transform: translateY(0);
    transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .site-header.header--hidden {
    transform: translateY(-100%);
  }

  .header-accent {
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-terra);
  }

  /* ── Toggle icon swap ── */
  .toggle-icon-close { display: none; }
  .toggle-icon-menu  { display: flex; }

  #menu-toggle.is-open .toggle-icon-menu  { display: none; }
  #menu-toggle.is-open .toggle-icon-close { display: flex; }

  /* ── Logo ── */
  .logo-link {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    text-decoration: none;
    display: flex;
    align-items: baseline;
    transition: opacity 0.2s;
  }

  .logo-link:hover { opacity: 0.75; }

  .logo-first {
    font-weight: 300;
    color: rgba(242, 235, 224, 0.55);
    letter-spacing: 0.03em;
  }

  .logo-sep {
    font-weight: 300;
    color: var(--color-terra);
    opacity: 0.6;
    font-size: 0.9em;
  }

  .logo-last {
    font-weight: 800;
    color: #f2ebe0;
    letter-spacing: -0.01em;
  }

  /* ── Desktop nav links ── */
  .nav-link {
    position: relative;
    color: rgba(242, 235, 224, 0.55);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    padding-bottom: 3px;
    transition: color 0.2s;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover           { color: white; }
  .nav-link:hover::after    { transform: scaleX(1); }
  .nav-link--active         { color: var(--color-accent); }
  .nav-link--active::after  { transform: scaleX(1); }

  /* ── Slide-down panel ── */
  .mobile-panel {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 45;
    background: rgba(14, 14, 14, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding-top: 52px; /* clears mobile header */
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.55);
    transform: translateY(-100%);
    transition: transform 0.36s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .mobile-panel { padding-top: 62px; }
  }

  .mobile-panel.is-open {
    transform: translateY(0);
    pointer-events: auto;
  }

  /* ── Panel links ── */
  .panel-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.055);
  }

  .panel-item:last-child { border-bottom: none; }

  .panel-link {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: rgba(242, 235, 224, 0.65);
    text-decoration: none;
    padding: 0.875rem 0;
    transition: color 0.2s;
  }

  .panel-link:hover       { color: rgba(242, 235, 224, 0.95); }
  .panel-link--active     { color: var(--color-accent); }

  /* ── Backdrop ── */
  .panel-backdrop {
    position: fixed;
    inset: 0;
    z-index: 35;
    background: rgba(0, 0, 0, 0.38);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .panel-backdrop.is-visible {
    opacity: 1;
    pointer-events: auto;
  }
</style>
