---
import Icon from './Icon.astro'
import { navLinks } from '../data/navigation'
import { SITE_NAME } from '../data/config'

const currentPath = Astro.url.pathname
---

<header class="fixed top-0 left-0 right-0 z-50 bg-base/80 backdrop-blur-md border-b border-subtle">
  <nav class="mx-auto flex max-w-[var(--container-grid)] items-center justify-between px-5 py-4" aria-label="Main navigation">
    <a href="/" class="font-[family-name:var(--font-heading)] text-lg text-primary hover:text-accent transition-colors">
      {SITE_NAME}
    </a>

    {/* Desktop nav */}
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath.startsWith(href) ? 'text-accent' : 'text-secondary hover:text-primary',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    {/* Mobile burger */}
    <button
      id="menu-toggle"
      class="md:hidden flex items-center justify-center w-11 h-11 -mr-2 text-secondary hover:text-primary transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <Icon name="menu" />
    </button>
  </nav>
</header>

{/* Mobile menu — outside header to avoid stacking context issues */}
<div
  id="mobile-menu"
  class="md:hidden fixed inset-0 z-[100] pointer-events-none"
>
  {/* Backdrop */}
  <div id="menu-backdrop" class="absolute inset-0 bg-base opacity-0 transition-opacity duration-300 ease-out" />

  {/* Panel */}
  <div id="menu-panel" class="relative h-full flex flex-col translate-y-[-8px] opacity-0 transition-all duration-300 ease-out">
    <div class="flex items-center justify-between px-5 py-4 border-b border-subtle">
      <a href="/" class="font-[family-name:var(--font-heading)] text-lg text-primary">
        {SITE_NAME}
      </a>
      <button
        id="menu-close"
        class="flex items-center justify-center w-11 h-11 -mr-2 text-secondary hover:text-primary transition-colors"
        aria-label="Close menu"
      >
        <Icon name="x" />
      </button>
    </div>
    <ul class="flex flex-col gap-2 p-5 pt-8">
      {navLinks.map(({ href, label }, i) => (
        <li>
          <a
            href={href}
            class:list={[
              'menu-link block py-3 text-2xl font-[family-name:var(--font-heading)] transition-all duration-300 opacity-0 translate-y-3',
              currentPath.startsWith(href) ? 'text-accent' : 'text-primary hover:text-accent',
            ]}
            style={`transition-delay: ${80 + i * 40}ms`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>

<div class="h-16"></div>

<script>
  function initMenu() {
    const toggle = document.getElementById('menu-toggle')
    const close = document.getElementById('menu-close')
    const menu = document.getElementById('mobile-menu')
    const backdrop = document.getElementById('menu-backdrop')
    const panel = document.getElementById('menu-panel')

    if (!toggle || !close || !menu || !backdrop || !panel) return

    let isOpen = false

    function openMenu() {
      if (isOpen) return
      isOpen = true

      menu.style.pointerEvents = 'auto'
      toggle.setAttribute('aria-expanded', 'true')
      document.body.style.overflow = 'hidden'

      requestAnimationFrame(() => {
        backdrop.style.opacity = '1'
        panel.style.opacity = '1'
        panel.style.transform = 'translateY(0)'
        menu.querySelectorAll('.menu-link').forEach((link) => {
          ;(link as HTMLElement).style.opacity = '1'
          ;(link as HTMLElement).style.transform = 'translateY(0)'
        })
      })
    }

    function closeMenu() {
      if (!isOpen) return
      isOpen = false

      toggle.setAttribute('aria-expanded', 'false')
      document.body.style.overflow = ''

      // Reset links first (they animate out faster)
      menu.querySelectorAll('.menu-link').forEach((link) => {
        ;(link as HTMLElement).style.opacity = '0'
        ;(link as HTMLElement).style.transform = 'translateY(12px)'
        ;(link as HTMLElement).style.transitionDelay = '0ms'
      })

      backdrop.style.opacity = '0'
      panel.style.opacity = '0'
      panel.style.transform = 'translateY(-8px)'

      // After transition, disable pointer events and restore link delays
      setTimeout(() => {
        if (!isOpen) {
          menu.style.pointerEvents = 'none'
          // Restore staggered delays for next open
          menu.querySelectorAll('.menu-link').forEach((link, i) => {
            ;(link as HTMLElement).style.transitionDelay = `${80 + i * 40}ms`
          })
        }
      }, 320)
    }

    toggle.addEventListener('click', openMenu)
    close.addEventListener('click', closeMenu)
    backdrop.addEventListener('click', closeMenu)

    menu.querySelectorAll('.menu-link').forEach((link) => {
      link.addEventListener('click', closeMenu)
    })
  }

  initMenu()
  document.addEventListener('astro:after-swap', initMenu)
</script>
