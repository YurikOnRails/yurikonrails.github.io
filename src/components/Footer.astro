---
import Icon from './Icon.astro'
import { profile } from '../data/profile'
import { navLinks } from '../data/navigation'
import { SITE_NAME } from '../data/config'

const socialLinks = [
  profile.social.github && { href: profile.social.github, label: 'GitHub', icon: 'github' },
  profile.social.telegram && { href: profile.social.telegram, label: 'Telegram', icon: 'telegram' },
].filter(Boolean) as { href: string; label: string; icon: string }[]

const year = new Date().getFullYear()
---

<footer class="mt-32 border-t border-subtle">
  <div class="mx-auto max-w-[var(--container-grid)] px-5">

    {/* Main footer grid */}
    <div class="grid grid-cols-1 gap-8 py-10 md:grid-cols-12 md:gap-8">

      {/* Brand column */}
      <div class="md:col-span-5">
        <a href="/" class="inline-block font-[family-name:var(--font-heading)] text-xl text-primary hover:text-accent transition-colors">
          {SITE_NAME}
        </a>
        <p class="mt-3 max-w-sm text-sm leading-relaxed text-secondary">
          {profile.bio}
        </p>
      </div>

      {/* Navigation column */}
      <div class="md:col-span-3 md:col-start-7">
        <h3 class="text-xs font-medium uppercase tracking-widest text-secondary mb-4">Navigate</h3>
        <ul class="space-y-2">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-sm text-primary/70 hover:text-accent transition-colors"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Connect column */}
      <div class="md:col-span-3">
        <h3 class="text-xs font-medium uppercase tracking-widest text-secondary mb-4">Connect</h3>
        <ul class="space-y-2">
          {socialLinks.map(({ href, label, icon }) => (
            <li>
              <a
                href={href}
                target={href.startsWith('/') ? undefined : '_blank'}
                rel={href.startsWith('/') ? undefined : 'noopener noreferrer'}
                class="inline-flex items-center gap-2 text-sm text-primary/70 hover:text-accent transition-colors"
              >
                <Icon name={icon} size={16} />
                <span>{label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    {/* Bottom bar */}
    <div class="border-t border-subtle flex flex-col items-center justify-between gap-3 py-6 md:flex-row">
      <p class="text-xs text-secondary">
        &copy; {year} {profile.name}. Planet Earth.
      </p>
      <p class="text-xs text-secondary/50 inline-flex items-center gap-1">
        Built with <Icon name="heart" size={12} class="text-accent" /> curiosity and bad WiFi
      </p>
    </div>

  </div>
</footer>
