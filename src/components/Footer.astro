---
import Icon from './Icon.astro'
import { profile } from '../data/profile'
import { navLinks } from '../data/navigation'

const socialLinks = [
  profile.social.github && { href: profile.social.github, label: 'GitHub', icon: 'github' },
  profile.social.telegram && { href: profile.social.telegram, label: 'Telegram', icon: 'telegram' },
].filter(Boolean) as { href: string; label: string; icon: string }[]

const year = new Date().getFullYear()
const initials = profile.name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase()
---

<footer style="background: #1a1912; margin-top: 0;">

  {/* ── Top strip: Follow heading + badge ── */}
  <div class="mx-auto max-w-[var(--container-grid)] px-5 pt-14 pb-10">
    <div class="flex items-start justify-between">
      <div>
        <p class="text-xs uppercase tracking-widest mb-2" style="color: rgba(242,235,224,0.35);">Follow</p>
        <h2 class="text-3xl font-bold text-white" style="font-family: var(--font-heading); letter-spacing: -0.03em;">
          {profile.name}
        </h2>
      </div>

      {/* Monogram badge — like JH in Johnny Harris footer */}
      <div class="footer-badge">
        {initials}
      </div>
    </div>
  </div>

  {/* ── Divider ── */}
  <div class="mx-auto max-w-[var(--container-grid)] px-5">
    <div style="height: 1px; background: rgba(242,235,224,0.10);"></div>
  </div>

  {/* ── Nav columns ── */}
  <div class="mx-auto max-w-[var(--container-grid)] px-5 py-12">
    <div class="grid grid-cols-2 gap-10 md:grid-cols-4">

      {/* Navigate */}
      <div>
        <h3 class="text-xs uppercase tracking-widest mb-5 font-medium" style="color: rgba(242,235,224,0.30);">
          Navigate
        </h3>
        <ul class="space-y-3">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="footer-link text-sm"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Connect */}
      <div>
        <h3 class="text-xs uppercase tracking-widest mb-5 font-medium" style="color: rgba(242,235,224,0.30);">
          Connect
        </h3>
        <ul class="space-y-3">
          {socialLinks.map(({ href, label, icon }) => (
            <li>
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-link inline-flex items-center gap-2 text-sm"
              >
                <Icon name={icon} size={15} />
                <span>{label}</span>
              </a>
            </li>
          ))}
          {profile.email && (
            <li>
              <a href={`mailto:${profile.email}`} class="footer-link inline-flex items-center gap-2 text-sm">
                <Icon name="mail" size={15} />
                <span>Email</span>
              </a>
            </li>
          )}
        </ul>
      </div>

    </div>
  </div>

  {/* ── Bottom bar ── */}
  <div class="mx-auto max-w-[var(--container-grid)] px-5 pb-8">
    <div style="height: 1px; background: rgba(242,235,224,0.08); margin-bottom: 1.5rem;"></div>
    <p class="text-xs" style="color: rgba(242,235,224,0.25);">
      &copy; {year} {profile.name}
    </p>
  </div>

</footer>

<style>
  .footer-link {
    color: rgba(242, 235, 224, 0.55);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: rgba(242, 235, 224, 1);
  }

  .footer-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    border-radius: 4px;
    flex-shrink: 0;
  }
</style>
