---
import Icon from './Icon.astro'
import { profile } from '../data/profile'
import { navLinks } from '../data/navigation'

const socialLinks = [
  profile.social.github && { href: profile.social.github, label: 'GitHub', icon: 'github' },
  profile.social.telegram && { href: profile.social.telegram, label: 'Telegram', icon: 'telegram' },
].filter(Boolean) as { href: string; label: string; icon: string }[]

const year = new Date().getFullYear()
const [logoFirst, logoLast] = profile.name.toUpperCase().split(' ')
---

{/* ── Terra connect bar ── */}
<div class="footer-accent">
  <div class="mx-auto max-w-[var(--container-grid)] px-5 py-4 flex items-center justify-between gap-8 flex-wrap">
    <span class="accent-label">Connect</span>
    <div class="flex items-center gap-8 flex-wrap">
      {socialLinks.map(({ href, label, icon }) => (
        <a href={href} target="_blank" rel="noopener noreferrer" class="accent-link inline-flex items-center gap-2">
          <Icon name={icon} size={13} />
          {label}
        </a>
      ))}
      {profile.email && (
        <a href={`mailto:${profile.email}`} class="accent-link inline-flex items-center gap-2">
          <Icon name="mail" size={13} />
          Email
        </a>
      )}
    </div>
  </div>
</div>

{/* ── Main footer ── */}
<footer class="footer-main">
  <div class="mx-auto max-w-[var(--container-grid)] px-5 py-14 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-12 md:gap-16">

      {/* ── Brand column ── */}
      <div>
        <p class="footer-brand">
          <span class="brand-first">{logoFirst}</span><span class="brand-sep"> · </span><span class="brand-last">{logoLast}</span>
        </p>
        <p class="footer-bio">{profile.bio}</p>
      </div>

      {/* ── Navigate column ── */}
      <div>
        <p class="footer-col-label">Navigate</p>
        <nav class="flex flex-col gap-3">
          {navLinks.map(({ href, label }) => (
            <a href={href} class="footer-link">{label}</a>
          ))}
        </nav>
      </div>

    </div>
  </div>

  {/* ── Bottom strip ── */}
  <div class="mx-auto max-w-[var(--container-grid)] px-5 pb-8">
    <div class="footer-rule"></div>
    <div class="flex items-center justify-between gap-4 flex-wrap">
      <p class="footer-copy">&copy; {profile.name} {year}</p>
      <p class="footer-tagline">// built with curiosity and bad wifi</p>
    </div>
  </div>
</footer>

<style>
  /* ── Terra connect bar ── */
  .footer-accent {
    background: var(--color-terra);
  }

  .accent-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
    white-space: nowrap;
  }

  .accent-link {
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: color 0.2s;
  }

  .accent-link:hover {
    color: white;
  }

  /* ── Main footer ── */
  .footer-main {
    background: var(--color-dark);
    margin-top: 0;
  }

  /* ── Brand ── */
  .footer-brand {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.05;
    margin-bottom: 1.75rem;
  }

  .brand-first {
    font-weight: 300;
    color: rgba(242, 235, 224, 0.4);
    letter-spacing: 0.02em;
  }

  .brand-sep {
    font-weight: 300;
    color: var(--color-terra);
    opacity: 0.75;
  }

  .brand-last {
    font-weight: 800;
    color: #f2ebe0;
    letter-spacing: -0.03em;
  }

  .footer-bio {
    color: rgba(242, 235, 224, 0.55);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.75;
    max-width: 420px;
  }

  /* ── Navigate column ── */
  .footer-col-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(242, 235, 224, 0.3);
    margin-bottom: 1.25rem;
  }

  .footer-link {
    color: rgba(242, 235, 224, 0.5);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: rgba(242, 235, 224, 1);
  }

  /* ── Bottom strip ── */
  .footer-rule {
    height: 1px;
    background: rgba(242, 235, 224, 0.07);
    margin-bottom: 1.25rem;
  }

  .footer-copy {
    color: rgba(242, 235, 224, 0.25);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }

  .footer-tagline {
    color: rgba(242, 235, 224, 0.25);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.02em;
  }
</style>
